DOMUM_DOMAIN=example.test
DOMUM_EMAIL=admin@example.test
DOMUM_LAN_IP=127.0.0.1
DOMUM_TS_IP=
DOMUM_DATA_ROOT=/tmp/domum-data
DOMUM_SNAPSHOT_ROOT=/tmp/domum-snapshots
DOMUM_LOG_DIR=/tmp/domum-logs
DOMUM_STATE_ROOT=/tmp/domum-state
DOMUM_HOT_ROOT=/tmp/domum-hot
DOMUM_MEDIA_ROOT=/tmp/domum-media
DOMUM_DIR=/tmp/domum-core-media

PUID=1000
PGID=1000
TZ=Etc/UTC

CF_DNS_API_TOKEN=dummy-ci-token
TRAEFIK_IMAGE=traefik:latest
TRAEFIK_DASHBOARD_HOST=traefik.example.test
TRAEFIK_DASHBOARD_USERS_FILE=/tmp/domum-secrets/traefik_dashboard_users

TAILSCALE_IMAGE=tailscale/tailscale:stable
TS_AUTHKEY=

IMMICH_HOST=photos.example.test
IMMICH_SERVER_IMAGE=ghcr.io/immich-app/immich-server:release
IMMICH_MACHINE_LEARNING_IMAGE=ghcr.io/immich-app/immich-machine-learning:release
IMMICH_REDIS_IMAGE=docker.io/redis:6.2-alpine
IMMICH_POSTGRES_IMAGE=tensorchord/pgvecto-rs:pg14-v0.2.0
IMMICH_DB_USERNAME=postgres
IMMICH_DB_DATABASE_NAME=immich
IMMICH_DB_PASSWORD=dummy-ci-password
IMMICH_JWT_SECRET=dummy-ci-jwt-secret

JELLYFIN_IMAGE=lscr.io/linuxserver/jellyfin:latest
JELLYFIN_HOST=media.example.test
JELLYFIN_CONFIG_DIR=/tmp/domum-data/jellyfin/config
JELLYFIN_CACHE_DIR=/tmp/domum-hot/jellyfin-cache
JELLYFIN_MEDIA_ROOT=/tmp/domum-media

PLEX_IMAGE=lscr.io/linuxserver/plex:latest
PLEX_HOST=plex.example.test
PLEX_CONFIG_DIR=/tmp/domum-data/plex/config
PLEX_TRANSCODE_DIR=/tmp/domum-hot/plex-transcode
PLEX_MEDIA_ROOT=/tmp/domum-media
PLEX_CLAIM=
PLEX_ENABLE_HW_TRANSCODE=0

NAVIDROME_IMAGE=deluan/navidrome:latest
NAVIDROME_HOST=music.example.test
NAVIDROME_DATA_DIR=/tmp/domum-data/navidrome
NAVIDROME_CACHE_DIR=/tmp/domum-hot/music-cache
NAVIDROME_MUSIC_ROOT=/tmp/domum-media/music
NAVIDROME_USER=1000:1000
NAVIDROME_SCAN_SCHEDULE=@every 1h
NAVIDROME_LOG_LEVEL=info

CALIBRE_WEB_IMAGE=lscr.io/linuxserver/calibre-web:latest
CALIBRE_WEB_HOST=books.example.test
CALIBRE_WEB_CONFIG_DIR=/tmp/domum-data/calibre-web/config
CALIBRE_WEB_LIBRARY_DIR=/tmp/domum-media/books

KAVITA_IMAGE=jvmilazz0/kavita:latest
KAVITA_HOST=kavita.example.test
KAVITA_CONFIG_DIR=/tmp/domum-data/kavita/config
KAVITA_LIBRARY_DIR=/tmp/domum-media/books
KAVITA_STAGING_DIR=/tmp/domum-hot/books-import

UPTIME_KUMA_IMAGE=louislam/uptime-kuma:2
UPTIME_KUMA_HOST=status.example.test

RESTIC_REST_SERVER_IMAGE=restic/rest-server:latest

ENABLE_TRAEFIK=1
ENABLE_TAILSCALE=1
ENABLE_IMMICH=1
ENABLE_JELLYFIN=1
ENABLE_PLEX=1
ENABLE_NAVIDROME=1
ENABLE_CALIBRE_WEB=1
ENABLE_KAVITA=1
ENABLE_UPTIME_KUMA=1
ENABLE_RESTIC_REST_SERVER=1
