render_traefik_dynamic() {
  [[ "${ENABLE_TRAEFIK:-0}" == "1" ]] || return 0

  local dir="$DOMUM_DIR/compose/proxy/traefik/dynamic"
  [[ -d "$dir" ]] || return 0

  : "${TRAEFIK_DASHBOARD_HOST:?TRAEFIK_DASHBOARD_HOST is empty}"
  : "${DOMUM_DOMAIN:?DOMUM_DOMAIN is empty}"

  if ! cmd_exists envsubst; then
    die "envsubst not found. Install gettext-base (apt install -y gettext-base) and retry."
  fi

  local src dst rendered
  shopt -s nullglob
  for src in "$dir"/*.tmpl; do
    dst="${src%.tmpl}"
    # envsubst takes the literal '${VAR}' allowlist; we do not want shell expansion here.
    # shellcheck disable=SC2016
    rendered="$(envsubst '${TRAEFIK_DASHBOARD_HOST} ${DOMUM_DOMAIN}' < "$src")"
    if [[ "$rendered" == *'{{'* ]] || printf '%s' "$rendered" | grep -qE '\$\{[A-Z_][A-Z0-9_]*\}'; then
      die "Unresolved placeholder in $src after render — refusing to write $dst"
    fi
    printf '%s' "$rendered" > "$dst.partial"
    mv "$dst.partial" "$dst"
    chmod 0644 "$dst"
    echo "[domum-media] Rendered $(basename "$dst")"
  done
  shopt -u nullglob
}

ensure_networks() {
  local nets=("domum-proxy" "domum-internal")
  for n in "${nets[@]}"; do
    if ! docker network inspect "$n" >/dev/null 2>&1; then
      echo "[domum-media] Creating docker network: $n"
      docker network create "$n" >/dev/null
    fi
  done
}

ensure_dirs() {
  ensure_secret_dir
  ensure_state_dirs
  mkdir -p "$DOMUM_LOG_DIR"
  mkdir -p "$DOMUM_DATA_ROOT" "$DOMUM_SNAPSHOT_ROOT" "$DOMUM_CACHE_ROOT"
  mkdir -p "${JELLYFIN_CONFIG_DIR:-$DOMUM_DATA_ROOT/jellyfin/config}"
  mkdir -p "${JELLYFIN_CACHE_DIR:-$DOMUM_CACHE_ROOT/jellyfin}"
  mkdir -p "${PLEX_CONFIG_DIR:-$DOMUM_DATA_ROOT/plex/config}"
  mkdir -p "${PLEX_TRANSCODE_DIR:-$DOMUM_CACHE_ROOT/plex-transcode}"
  mkdir -p "${NAVIDROME_DATA_DIR:-$DOMUM_DATA_ROOT/navidrome}"
  mkdir -p "${CALIBRE_WEB_CONFIG_DIR:-$DOMUM_DATA_ROOT/calibre-web/config}"
  mkdir -p "${KAVITA_CONFIG_DIR:-$DOMUM_DATA_ROOT/kavita/config}"
  # Parent root only; music sources (subfolders / NFS / rclone mounts) are
  # assembled by the operator per docs/SETUP-NAVIDROME.md.
  mkdir -p "${NAVIDROME_MUSIC_ROOT:-$DOMUM_MEDIA_ROOT/music}"
  mkdir -p "${CALIBRE_WEB_LIBRARY_DIR:-$DOMUM_MEDIA_ROOT/books}"
  mkdir -p "${KAVITA_LIBRARY_DIR:-$DOMUM_MEDIA_ROOT/books}"

  if [[ "${ENABLE_CALIBRE_WEB:-0}" == "1" ]]; then
    local lib_dir="${CALIBRE_WEB_LIBRARY_DIR:-$DOMUM_MEDIA_ROOT/books}"
    if [[ ! -f "$lib_dir/metadata.db" ]]; then
      warn "Calibre-Web: no Calibre library found at $lib_dir."
      warn "  Initialize one after 'apply' completes — see docs/SETUP-PLEX-BOOKS-STORAGE.md."
    fi
  fi
}

compose_cmd() {
  local -a args
  export_env_for_compose
  mapfile -t args < <(compose_files_for_enabled_services)
  cd "$DOMUM_DIR"
  docker compose "${args[@]}" "$@"
}

# ---- btrfs snapshots ------------------------------------------------------

is_btrfs_subvol() {
  btrfs subvolume show "$1" >/dev/null 2>&1
}

snapshot_subvolumes() {
  local candidates=()
  candidates+=("$DOMUM_DATA_ROOT/immich")
  candidates+=("$DOMUM_DATA_ROOT/jellyfin")
  candidates+=("$DOMUM_DATA_ROOT/plex")
  candidates+=("$DOMUM_DATA_ROOT/navidrome")
  candidates+=("$DOMUM_DATA_ROOT/calibre-web")
  candidates+=("$DOMUM_DATA_ROOT/kavita")
  candidates+=("$DOMUM_DATA_ROOT/uptime-kuma")
  candidates+=("$DOMUM_DATA_ROOT/traefik")
  for c in "${candidates[@]}"; do
    [[ -d "$c" ]] && echo "$c"
  done
}

snapshot_create() {
  local tag="${1:-manual}"
  local stamp
  stamp="$(date +%Y%m%d-%H%M%S)"
  mkdir -p "$DOMUM_SNAPSHOT_ROOT"
  while IFS= read -r subvol; do
    local name target service
    name="$(basename "$subvol")"
    target="$DOMUM_SNAPSHOT_ROOT/${name}-${stamp}-${tag}"
    if is_btrfs_subvol "$subvol"; then
      echo "[domum-media] Snapshot: $subvol -> $target"
      btrfs subvolume snapshot -r "$subvol" "$target"
      service="$name"
      record_rollback_entry "$service" "$tag" "$(basename "$target")" "" "" >/dev/null
    else
      echo "[domum-media] Skipping non-subvolume path: $subvol"
    fi
  done < <(snapshot_subvolumes)
}

snapshot_list() {
  if [[ ! -d "$DOMUM_SNAPSHOT_ROOT" ]]; then
    echo "[domum-media] No snapshot root at $DOMUM_SNAPSHOT_ROOT"
    return 0
  fi
  ls -1tr "$DOMUM_SNAPSHOT_ROOT"
}

snapshot_path_mtime() {
  local path="$1"
  if stat -c %Y "$path" >/dev/null 2>&1; then
    stat -c %Y "$path"
  else
    stat -f %m "$path"
  fi
}

service_snapshot_base_name() {
  local service="$1"
  local path
  path="$(service_data_path "$service" 2>/dev/null || echo "$service")"
  basename -- "$path"
}

list_snapshots_for_base() {
  local base="$1"
  local tmp_file path name mtime

  [[ -d "$DOMUM_SNAPSHOT_ROOT" ]] || return 0

  tmp_file="$(mktemp)"
  shopt -s nullglob
  for path in "$DOMUM_SNAPSHOT_ROOT"/"$base"-*; do
    [[ -d "$path" ]] || continue
    name="$(basename -- "$path")"
    mtime="$(snapshot_path_mtime "$path")" || continue
    printf '%s\t%s\n' "$mtime" "$name" >> "$tmp_file"
  done
  shopt -u nullglob

  if [[ -s "$tmp_file" ]]; then
    sort -n "$tmp_file" | cut -f2-
  fi
  rm -f "$tmp_file"
}

snapshot_metadata_dir() {
  printf '%s/snapshots' "$DOMUM_STATE_ROOT"
}

record_service_snapshot_metadata() {
  local service="$1"
  local before_version="$2"
  local after_version="$3"
  local snapshot_name="$4"
  local status="${5:-created}"
  local meta_dir meta_file
  meta_dir="$(snapshot_metadata_dir)"
  install -d -m 0700 "$meta_dir"
  meta_file="$meta_dir/${snapshot_name}.env"
  cat > "$meta_file" <<EOF
SERVICE='$service'
VERSION_BEFORE='$before_version'
VERSION_AFTER='$after_version'
SNAPSHOT_NAME='$snapshot_name'
TIMESTAMP='$(date -Iseconds)'
STATUS='$status'
EOF
  chmod 600 "$meta_file"
}

create_service_snapshot() {
  local service="$1"
  local tag="$2"
  local before_version="${3:-unknown}"
  local after_version="${4:-unknown}"
  local data_path snapshot_name event

  data_path="$(service_data_path "$service")" || return 1
  [[ -d "$data_path" ]] || return 1
  snapshot_name="$(basename "$data_path")-$(date +%Y%m%d-%H%M%S)-${tag}"
  if is_btrfs_subvol "$data_path"; then
    mkdir -p "$DOMUM_SNAPSHOT_ROOT"
    echo "[domum-media] Snapshot: $data_path -> $DOMUM_SNAPSHOT_ROOT/$snapshot_name"
    btrfs subvolume snapshot -r "$data_path" "$DOMUM_SNAPSHOT_ROOT/$snapshot_name"
    record_service_snapshot_metadata "$service" "$before_version" "$after_version" "$snapshot_name"
    event="${tag#pre-}"
    record_rollback_entry "$service" "$event" "$snapshot_name" "$before_version" "$after_version" >/dev/null
    printf '%s' "$snapshot_name"
    return 0
  fi
  return 1
}

snapshot_prune() {
  local keep="${SNAPSHOT_KEEP_PER_SUBVOL:-14}"
  [[ -d "$DOMUM_SNAPSHOT_ROOT" ]] || return 0
  local names
  names="$(find "$DOMUM_SNAPSHOT_ROOT" -mindepth 1 -maxdepth 1 -printf '%f\n' 2>/dev/null | sed -E 's/-[0-9]{8}-[0-9]{6}-.*$//' | sort -u || true)"
  while IFS= read -r base; do
    [[ -n "$base" ]] || continue
    local snaps
    mapfile -t snaps < <(list_snapshots_for_base "$base")
    local total="${#snaps[@]}"
    local drop=$(( total - keep ))
    if (( drop > 0 )); then
      local i
      for (( i = 0; i < drop; i++ )); do
        local victim="$DOMUM_SNAPSHOT_ROOT/${snaps[$i]}"
        echo "[domum-media] Pruning snapshot: $victim"
        btrfs subvolume delete "$victim" || true
      done
    fi
  done <<< "$names"
}

list_service_snapshots() {
  [[ -d "$DOMUM_SNAPSHOT_ROOT" ]] || return 0
  list_snapshots_for_base "$(service_snapshot_base_name "$1")"
}

restore_snapshot_for_service() {
  local service="$1"
  local snapshot_name="$2"
  local data_path current_backup compose_svcs

  data_path="$(service_data_path "$service")" || die "No data path mapping for $service"
  [[ -d "$DOMUM_SNAPSHOT_ROOT/$snapshot_name" ]] || die "Snapshot not found: $snapshot_name"

  compose_svcs="$(service_compose_services "$service" || true)"
  # shellcheck disable=SC2086
  [[ -n "$compose_svcs" ]] && compose_cmd stop $compose_svcs 2>/dev/null || true

  if [[ -d "$data_path" ]] && is_btrfs_subvol "$data_path"; then
    current_backup="${data_path}.rollback-$(date +%Y%m%d-%H%M%S)"
    mv "$data_path" "$current_backup"
  elif [[ -e "$data_path" ]]; then
    rm -rf "$data_path"
  fi

  echo "[domum-media] Restoring $service from $snapshot_name"
  btrfs subvolume snapshot "$DOMUM_SNAPSHOT_ROOT/$snapshot_name" "$data_path"
  # shellcheck disable=SC2086
  [[ -n "$compose_svcs" ]] && compose_cmd up -d $compose_svcs
}

latest_snapshot_for_service() {
  list_service_snapshots "$1" | tail -n 1
}

# ---- timer syncing --------------------------------------------------------

normalize_daily_schedule() {
  local value="$1"
  if [[ "$value" =~ ^[0-9]{2}:[0-9]{2}$ ]]; then
    printf '*-*-* %s:00' "$value"
    return 0
  fi
  if [[ "$value" == *"*-*-*"* ]]; then
    printf '%s' "$value"
    return 0
  fi
  die "Invalid daily schedule '$value' (expected HH:MM or full systemd OnCalendar string)"
}

normalize_weekly_schedule() {
  local value="$1"
  if [[ "$value" =~ ^(Mon|Tue|Wed|Thu|Fri|Sat|Sun)[[:space:]]+[0-9]{2}:[0-9]{2}$ ]]; then
    printf '%s *-*-* %s:00' "${value%% *}" "${value##* }"
    return 0
  fi
  if [[ "$value" == *"*-*-*"* ]]; then
    printf '%s' "$value"
    return 0
  fi
  die "Invalid weekly schedule '$value' (expected 'Sun 03:30' or full systemd OnCalendar string)"
}

write_timer_override() {
  local unit="$1"
  local oncalendar="$2"
  local randomized_delay="$3"
  local dir="/etc/systemd/system/${unit}.d"
  install -d "$dir"
  cat > "${dir}/override.conf" <<EOF
[Timer]
OnCalendar=
OnCalendar=${oncalendar}
RandomizedDelaySec=${randomized_delay}
Persistent=true
EOF
}

sync_unattended_upgrades() {
  local auto_cfg="/etc/apt/apt.conf.d/20auto-upgrades"
  local domum_cfg="/etc/apt/apt.conf.d/50domum-unattended-upgrades"
  local reboot_flag="false"

  if [[ "${HOST_AUTO_REBOOT_ENABLED:-0}" == "1" ]]; then
    reboot_flag="true"
  fi

  cat > "$auto_cfg" <<EOF
APT::Periodic::Update-Package-Lists "1";
APT::Periodic::Unattended-Upgrade "${HOST_SECURITY_AUTO_UPDATE_ENABLED:-1}";
EOF

  cat > "$domum_cfg" <<EOF
Unattended-Upgrade::Origins-Pattern {
  "origin=Debian,codename=\${distro_codename}-security,label=Debian-Security";
};
Unattended-Upgrade::Package-Blacklist {
  "docker-ce";
  "docker-ce-cli";
  "docker-buildx-plugin";
  "docker-compose-plugin";
  "containerd.io";
};
Unattended-Upgrade::AutoFixInterruptedDpkg "true";
Unattended-Upgrade::MinimalSteps "true";
Unattended-Upgrade::Remove-Unused-Dependencies "true";
Unattended-Upgrade::Automatic-Reboot "${reboot_flag}";
Unattended-Upgrade::Automatic-Reboot-Time "${HOST_AUTO_REBOOT_WINDOW_START:-03:00}";
EOF

  systemctl enable --now unattended-upgrades.service apt-daily-upgrade.timer >/dev/null 2>&1 || true
}

sync_timer_overrides() {
  local backup_calendar check_calendar prune_calendar image_update_calendar host_update_calendar
  backup_calendar="$(normalize_daily_schedule "${BACKUP_DAILY_AT:-02:30}")"
  check_calendar="$(normalize_weekly_schedule "${CHECK_WEEKLY_AT:-Sun 03:30}")"
  prune_calendar="$(normalize_weekly_schedule "${SNAPSHOT_PRUNE_WEEKLY_AT:-Sun 04:30}")"
  image_update_calendar="$(normalize_daily_schedule "${IMAGE_AUTO_UPDATE_AT:-05:15}")"
  host_update_calendar="$(normalize_weekly_schedule "${HOST_PACKAGE_AUTO_UPDATE_AT:-Mon 05:45}")"
  write_timer_override "domum-media-backup.timer" "$backup_calendar" "15m"
  write_timer_override "domum-media-check.timer" "$check_calendar" "20m"
  write_timer_override "domum-media-btrfs-snapshot.timer" "$prune_calendar" "20m"
  write_timer_override "domum-media-image-refresh.timer" "$image_update_calendar" "${IMAGE_AUTO_UPDATE_RANDOMIZED_DELAY:-30m}"
  write_timer_override "domum-media-host-update.timer" "$host_update_calendar" "${HOST_PACKAGE_AUTO_UPDATE_RANDOMIZED_DELAY:-45m}"

  systemctl daemon-reload
  systemctl enable --now \
    domum-media-backup.timer \
    domum-media-check.timer \
    domum-media-btrfs-snapshot.timer \
    domum-media-image-refresh.timer \
    domum-media-host-update.timer \
    domum-media-dr-reminder.timer >/dev/null

  # Best-effort: disable the retired hot-prune timer on hosts upgraded from an
  # older release that still has the unit installed.
  systemctl disable --now domum-media-hot-prune.timer >/dev/null 2>&1 || true

  sync_unattended_upgrades
}

# ---- configure flow -------------------------------------------------------

config_set() {
  local key="$1"
  local value="${2:-}"
  local rendered tmp
  printf -v rendered '%q' "$value"
  tmp="$(mktemp)"
  awk -v key="$key" -v val="$rendered" '
    BEGIN { updated = 0 }
    $0 ~ "^" key "=" {
      print key "=" val
      updated = 1
      next
    }
    { print }
    END {
      if (!updated) {
        print key "=" val
      }
    }
  ' "$CFG_FILE" > "$tmp"
  mv "$tmp" "$CFG_FILE"
}

prompt_with_default() {
  local label="$1"
  local current="${2:-}"
  local reply
  read -r -p "$label [$current]: " reply
  printf '%s' "${reply:-$current}"
}

prompt_yes_no() {
  local label="$1"
  local current="${2:-0}"
  local default="n"
  local reply
  [[ "$current" == "1" ]] && default="y"
  while true; do
    read -r -p "$label [y/n] (default: $default): " reply
    reply="${reply:-$default}"
    case "${reply,,}" in
      y|yes) echo "1"; return 0 ;;
      n|no)  echo "0"; return 0 ;;
    esac
  done
}

prompt_choice() {
  local label="$1"
  local current="$2"
  shift 2
  local reply
  while true; do
    read -r -p "$label [$current] ($(printf '%s ' "$@")): " reply
    reply="${reply:-$current}"
    for option in "$@"; do
      if [[ "$reply" == "$option" ]]; then
        echo "$reply"
        return 0
      fi
    done
  done
}

configure_text_value() {
  local key="$1"
  local label="$2"
  local current="${!key:-}"
  config_set "$key" "$(prompt_with_default "$label" "$current")"
}

configure_service_toggle() {
  local key="$1"
  local label="$2"
  local current="${!key:-0}"
  config_set "$key" "$(prompt_yes_no "$label" "$current")"
}

configure_image_behavior() {
  local image_key="$1"
  local auto_key="$2"
  local delay_key="$3"
  local label="$4"
  local auto_enabled

  echo
  echo "Image policy: $label"
  config_set "$image_key" "$(prompt_with_default "Container image ref for $label" "${!image_key:-}")"
  auto_enabled="$(prompt_yes_no "Auto-update $label when a newer image is available?" "${!auto_key:-0}")"
  config_set "$auto_key" "$auto_enabled"
  if [[ "$auto_enabled" == "1" ]]; then
    config_set "$delay_key" "$(prompt_with_default "Delay in days before applying the new $label image" "${!delay_key:-7}")"
  fi
}

configure_secret_file_prompt() {
  local path="$1"
  local label="$2"
  local value
  value="$(prompt_secret_value "$label" "$path")"
  [[ -n "$value" ]] || return 0
  write_secret_file "$path" "$value"
}

configure_generated_secret_prompt() {
  local path="$1"
  local label="$2"
  local value
  value="$(prompt_secret_value "$label" "$path")"
  if [[ -z "$value" ]]; then
    [[ -f "$path" ]] && return 0
    value="$(generate_secret 32)"
    echo "[domum-media] Generated value for $label."
  fi
  write_secret_file "$path" "$value"
}

configure_multiline_secret_prompt() {
  local path="$1"
  local label="$2"
  local value rc
  if value="$(prompt_multiline_value "$label" "$path")"; then
    :
  else
    rc=$?
    [[ "$rc" -eq 10 ]] && return 0
    return "$rc"
  fi
  validate_backup_env_content "$value" \
    || die "Invalid backup env file: $path. It must contain valid shell export/key=value lines."
  write_secret_file "$path" "$value"
}

configure_traefik_dashboard_secret() {
  local path="${TRAEFIK_DASHBOARD_USERS_FILE:-$SECRETS_DIR/traefik_dashboard_users}"
  local username password hash
  local current_user="admin"

  if [[ -f "$path" ]]; then
    current_user="$(cut -d: -f1 "$path" 2>/dev/null || echo admin)"
  fi

  username="$(prompt_with_default "Traefik dashboard username" "$current_user")"
  password="$(prompt_secret_value "Traefik dashboard password" "$path")"
  [[ -n "$password" ]] || return 0

  hash="$(htpasswd_hash "$username" "$password")"
  write_secret_file "$path" "$hash"
}

configure_service_secrets() {
  ensure_secret_dir

  echo
  echo "Secrets"

  if [[ "${ENABLE_TRAEFIK:-0}" == "1" ]]; then
    configure_secret_file_prompt "$SECRETS_DIR/cloudflare_api_token" "Cloudflare DNS API token"
    configure_traefik_dashboard_secret
  fi

  if [[ "${ENABLE_IMMICH:-0}" == "1" ]]; then
    if immich_db_password_initialized; then
      cat <<EOF
[domum-media] Immich Postgres is already initialized at $(immich_postgres_data_dir).
  Changing immich_db_password here will cause 'domum-media apply' to refuse
  to deploy until you either restore the old value or run:
      sudo domum-media immich reset-db
  Press Enter to keep the current value if you do not intend to rotate it.
EOF
    fi
    configure_generated_secret_prompt "$SECRETS_DIR/immich_db_password" "Immich database password"
    configure_generated_secret_prompt "$SECRETS_DIR/immich_jwt_secret" "Immich JWT secret"
  fi

  while IFS= read -r target; do
    backup_target_enabled "$target" || continue
    configure_generated_secret_prompt "$(backup_target_password_file "$target")" "Restic password for $target"

    case "$(backup_target_value "$target" TYPE repository)" in
      repository)
        local env_file
        env_file="$(backup_target_value "$target" ENV_FILE)"
        if [[ -n "$env_file" ]]; then
          configure_multiline_secret_prompt "$env_file" "Backend env file for $target (for example B2_ACCOUNT_ID=... / B2_ACCOUNT_KEY=...)"
        fi
        ;;
      ftp)
        configure_secret_file_prompt \
          "$(backup_target_value "$target" FTP_USERNAME_FILE "$SECRETS_DIR/${target}_ftp_username")" \
          "FTP username for $target"
        configure_secret_file_prompt \
          "$(backup_target_value "$target" FTP_PASSWORD_FILE "$SECRETS_DIR/${target}_ftp_password")" \
          "FTP password for $target"
        ;;
    esac
  done < <(backup_target_names)
}

configure_backup_target() {
  local target="$1"
  local upper
  upper="$(uppercase_token "$target")"

  echo
  echo "Backup target: $target"

  local enabled
  enabled="$(prompt_yes_no "Enable $target backup target?" "$(backup_target_value "$target" ENABLED 0)")"
  config_set "BACKUP_TARGET_${upper}_ENABLED" "$enabled"
  if [[ "$enabled" != "1" ]]; then
    return 0
  fi

  local target_type
  target_type="$(prompt_choice "Target type for $target" "$(backup_target_value "$target" TYPE repository)" repository nfs ftp)"
  config_set "BACKUP_TARGET_${upper}_TYPE" "$target_type"
  config_set "BACKUP_TARGET_${upper}_RETENTION" \
    "$(prompt_choice "Retention cadence for $target" "$(backup_target_value "$target" RETENTION none)" daily weekly none)"

  case "$target_type" in
    repository)
      local repo_url
      repo_url="$(prompt_with_default "Restic repository string for $target" "$(backup_target_value "$target" REPOSITORY)")"
      config_set "BACKUP_TARGET_${upper}_REPOSITORY" "$repo_url"
      config_set "BACKUP_TARGET_${upper}_PASSWORD_FILE" \
        "$(prompt_with_default "Password file for $target" "$(backup_target_password_file "$target")")"
      config_set "BACKUP_TARGET_${upper}_ENV_FILE" \
        "$(prompt_with_default "Optional backend credential env file for $target" "$(backup_target_value "$target" ENV_FILE)")"
      if [[ "$repo_url" == sftp:* ]]; then
        local use_key
        use_key="$(prompt_yes_no "Use SSH key authentication (required for unattended backup)?" "1")"
        if [[ "$use_key" == "1" ]]; then
          config_set "BACKUP_TARGET_${upper}_SFTP_KEY_FILE" \
            "$(prompt_with_default "Path to SSH private key" \
              "$(backup_target_value "$target" SFTP_KEY_FILE "$SECRETS_DIR/hetzner_storagebox_ed25519")")"
          config_set "BACKUP_TARGET_${upper}_SFTP_KNOWN_HOSTS_FILE" \
            "$(prompt_with_default "Path to known_hosts file (or blank)" \
              "$(backup_target_value "$target" SFTP_KNOWN_HOSTS_FILE "$SECRETS_DIR/hetzner_storagebox_known_hosts")")"
          config_set "BACKUP_TARGET_${upper}_SFTP_PORT" \
            "$(prompt_with_default "SFTP port (Hetzner Storage Box = 23)" \
              "$(backup_target_value "$target" SFTP_PORT 22)")"
        fi
      fi
      local profile profile_default
      profile_default="custom"
      [[ "$target" == "cloud" ]] && profile_default="immich-only"
      profile="$(prompt_choice "Include paths profile for $target" "$profile_default" \
        "immich-only" "all-data" "custom")"
      case "$profile" in
        immich-only)
          config_set "BACKUP_TARGET_${upper}_INCLUDE_PATHS" \
            "/srv/data/immich/library /srv/data/immich/backup-staging /var/lib/domum-media/recovery-pack" ;;
        all-data)
          config_set "BACKUP_TARGET_${upper}_INCLUDE_PATHS" "/srv/data /srv/media/books" ;;
        custom)
          config_set "BACKUP_TARGET_${upper}_INCLUDE_PATHS" \
            "$(prompt_with_default "Include paths (space-separated)" \
              "$(backup_target_value "$target" INCLUDE_PATHS "${BACKUP_INCLUDE_PATHS:-/srv/data}")")" ;;
      esac
      ;;
    nfs)
      config_set "BACKUP_TARGET_${upper}_NFS_REMOTE" \
        "$(prompt_with_default "NFS remote for $target (server:/export/path)" "$(backup_target_value "$target" NFS_REMOTE)")"
      config_set "BACKUP_TARGET_${upper}_NFS_MOUNT_POINT" \
        "$(prompt_with_default "Local mount point for $target" "$(backup_target_value "$target" NFS_MOUNT_POINT "/mnt/domum-media-$target")")"
      config_set "BACKUP_TARGET_${upper}_REPOSITORY" \
        "$(prompt_with_default "Restic repo path on mounted NFS share" "$(backup_target_value "$target" REPOSITORY "/mnt/domum-media-$target/restic")")"
      config_set "BACKUP_TARGET_${upper}_PASSWORD_FILE" \
        "$(prompt_with_default "Password file for $target" "$(backup_target_password_file "$target")")"
      ;;
    ftp)
      config_set "BACKUP_TARGET_${upper}_FTP_HOST" \
        "$(prompt_with_default "FTP host for $target" "$(backup_target_value "$target" FTP_HOST)")"
      config_set "BACKUP_TARGET_${upper}_FTP_PORT" \
        "$(prompt_with_default "FTP port for $target" "$(backup_target_value "$target" FTP_PORT 21)")"
      config_set "BACKUP_TARGET_${upper}_FTP_REMOTE_NAME" \
        "$(prompt_with_default "Temporary rclone remote name for $target" "$(backup_target_value "$target" FTP_REMOTE_NAME "$target")")"
      config_set "BACKUP_TARGET_${upper}_FTP_PATH" \
        "$(prompt_with_default "Remote FTP path for $target" "$(backup_target_value "$target" FTP_PATH "/domum-media")")"
      config_set "BACKUP_TARGET_${upper}_FTP_USERNAME_FILE" \
        "$(prompt_with_default "FTP username file for $target" "$(backup_target_value "$target" FTP_USERNAME_FILE "$SECRETS_DIR/${target}_ftp_username")")"
      config_set "BACKUP_TARGET_${upper}_FTP_PASSWORD_FILE" \
        "$(prompt_with_default "FTP password file for $target" "$(backup_target_value "$target" FTP_PASSWORD_FILE "$SECRETS_DIR/${target}_ftp_password")")"
      config_set "BACKUP_TARGET_${upper}_PASSWORD_FILE" \
        "$(prompt_with_default "Restic repository password file for $target" "$(backup_target_password_file "$target")")"
      ;;
  esac
}

apply_update_delay_profile() {
  local profile="$1"
  local class_a_delay class_b_delay class_c_delay

  case "$profile" in
    Conservative) class_a_delay=14; class_b_delay=30; class_c_delay=30 ;;
    Balanced)     class_a_delay=14; class_b_delay=21; class_c_delay=21 ;;
    Fresh)        class_a_delay=7;  class_b_delay=7;  class_c_delay=7 ;;
    *) die "Unknown update profile: $profile" ;;
  esac

  config_set TRAEFIK_AUTO_UPDATE 1
  config_set TAILSCALE_AUTO_UPDATE 1
  config_set UPTIME_KUMA_AUTO_UPDATE 1
  config_set RESTIC_REST_SERVER_AUTO_UPDATE 1
  config_set TRAEFIK_AUTO_UPDATE_DELAY_DAYS "$class_a_delay"
  config_set TAILSCALE_AUTO_UPDATE_DELAY_DAYS "$class_a_delay"
  config_set UPTIME_KUMA_AUTO_UPDATE_DELAY_DAYS "$class_a_delay"
  config_set RESTIC_REST_SERVER_AUTO_UPDATE_DELAY_DAYS "$class_a_delay"

  config_set JELLYFIN_AUTO_UPDATE 1
  config_set PLEX_AUTO_UPDATE 1
  config_set NAVIDROME_AUTO_UPDATE 1
  config_set CALIBRE_WEB_AUTO_UPDATE 1
  config_set KAVITA_AUTO_UPDATE 1
  config_set JELLYFIN_AUTO_UPDATE_DELAY_DAYS "$class_b_delay"
  config_set PLEX_AUTO_UPDATE_DELAY_DAYS "$class_b_delay"
  config_set NAVIDROME_AUTO_UPDATE_DELAY_DAYS "$class_b_delay"
  config_set CALIBRE_WEB_AUTO_UPDATE_DELAY_DAYS "$class_b_delay"
  config_set KAVITA_AUTO_UPDATE_DELAY_DAYS "$class_b_delay"

  config_set IMMICH_BUNDLE_DELAY_DAYS "$class_c_delay"
}

configure_non_interactive() {
  need_root
  ensure_cfg_file
  load_cfg
  export_env_for_compose
  ensure_secret_dir
  converge_local_installation
  sync_timer_overrides
  echo "[domum-media] Non-interactive configure complete."
}

configure_cmd() {
  if [[ "${1:-}" == "--non-interactive" ]]; then
    configure_non_interactive
    return 0
  fi

  need_root
  ensure_cfg_file
  load_cfg
  export_env_for_compose
  ensure_secret_dir
  converge_local_installation

  echo "[domum-media] Interactive configuration"
  echo "Press Enter to keep the current value."
  echo

  configure_text_value DOMUM_DOMAIN "Base domain"
  configure_text_value DOMUM_EMAIL "ACME email for Let's Encrypt"
  configure_text_value DOMUM_LAN_IP "LAN IP for split-DNS notes"
  configure_text_value DOMUM_TS_IP "Tailscale IP for split-DNS notes"

  echo
  configure_service_toggle ENABLE_TRAEFIK "Enable Traefik reverse proxy?"
  configure_service_toggle ENABLE_TAILSCALE "Enable Tailscale container?"
  configure_service_toggle ENABLE_IMMICH "Enable Immich?"
  configure_service_toggle ENABLE_JELLYFIN "Enable Jellyfin?"
  configure_service_toggle ENABLE_PLEX "Enable Plex?"
  configure_service_toggle ENABLE_NAVIDROME "Enable Navidrome (music)?"
  configure_service_toggle ENABLE_CALIBRE_WEB "Enable Calibre-Web?"
  configure_service_toggle ENABLE_KAVITA "Enable Kavita?"
  configure_service_toggle ENABLE_UPTIME_KUMA "Enable Uptime Kuma?"
  configure_service_toggle ENABLE_RESTIC_REST_SERVER "Enable local restic REST server?"

  ensure_cfg_file
  load_cfg
  export_env_for_compose

  if [[ "${ENABLE_TRAEFIK:-0}" == "1" ]]; then
    configure_text_value TRAEFIK_DASHBOARD_HOST "Traefik dashboard hostname"
  fi
  if [[ "${ENABLE_IMMICH:-0}" == "1" ]]; then
    configure_text_value IMMICH_HOST "Immich hostname"
  fi
  if [[ "${ENABLE_JELLYFIN:-0}" == "1" ]]; then
    configure_text_value JELLYFIN_HOST "Jellyfin hostname"
  fi
  if [[ "${ENABLE_PLEX:-0}" == "1" ]]; then
    configure_text_value PLEX_HOST "Plex hostname"
  fi
  if [[ "${ENABLE_NAVIDROME:-0}" == "1" ]]; then
    configure_text_value NAVIDROME_HOST "Navidrome hostname"
  fi
  if [[ "${ENABLE_CALIBRE_WEB:-0}" == "1" ]]; then
    configure_text_value CALIBRE_WEB_HOST "Calibre-Web hostname"
  fi
  if [[ "${ENABLE_KAVITA:-0}" == "1" ]]; then
    configure_text_value KAVITA_HOST "Kavita hostname"
  fi

  echo
  local freshness_profile immich_policy
  freshness_profile="$(prompt_choice "How fresh should app updates be?" "Balanced" Conservative Balanced Fresh)"
  apply_update_delay_profile "$freshness_profile"
  immich_policy="$(prompt_choice "Immich update policy" "Bundle auto-update" "Bundle auto-update" "Notify only" "Manage manually")"
  case "$immich_policy" in
    "Bundle auto-update") config_set IMMICH_BUNDLE_AUTO_UPDATE 1 ;;
    "Notify only") config_set IMMICH_BUNDLE_AUTO_UPDATE 0 ;;
    "Manage manually") config_set IMMICH_BUNDLE_AUTO_UPDATE 0 ;;
  esac
  config_set BACKUP_POLICY \
    "$(prompt_choice "Backup gate policy for updates" "${BACKUP_POLICY:-BALANCED}" STRICT BALANCED LENIENT)"
  config_set AUTO_ROLLBACK_ENABLED \
    "$(prompt_yes_no "Enable automatic rollback if a service health check fails?" "${AUTO_ROLLBACK_ENABLED:-1}")"
  config_set IMMICH_BUNDLE_ROLLBACK_ENABLED \
    "$(prompt_yes_no "Enable Immich bundle rollback on failed health validation?" "${IMMICH_BUNDLE_ROLLBACK_ENABLED:-1}")"
  config_set CLEANUP_IMAGES_AFTER_UPDATE \
    "$(prompt_yes_no "Automatically clean up old Docker images after successful updates?" "${CLEANUP_IMAGES_AFTER_UPDATE:-1}")"
  config_set HOST_SECURITY_AUTO_UPDATE_ENABLED \
    "$(prompt_yes_no "Enable unattended Debian security patches?" "${HOST_SECURITY_AUTO_UPDATE_ENABLED:-1}")"
  local recovery_pack_enabled
  recovery_pack_enabled="$(prompt_yes_no "Enable encrypted recovery-pack creation?" "${RECOVERY_PACK_ENABLED:-1}")"
  config_set RECOVERY_PACK_ENABLED "$recovery_pack_enabled"
  if [[ "$recovery_pack_enabled" == "1" ]]; then
    config_set RECOVERY_PACK_AGE_PUBKEY_FILE \
      "$(prompt_with_default "Path to the age public key for recovery-pack encryption" "${RECOVERY_PACK_AGE_PUBKEY_FILE:-$SECRETS_DIR/recovery_pack_pubkey}")"
  fi

  if [[ "${ENABLE_IMMICH:-0}" == "1" ]]; then
    config_set IMMICH_BUNDLE_DELAY_DAYS \
      "$(prompt_with_default "Delay in days before applying a new Immich bundle" "${IMMICH_BUNDLE_DELAY_DAYS:-21}")"
  fi

  echo
  config_set BACKUP_DAILY_AT \
    "$(prompt_with_default "Daily backup time (HH:MM)" "${BACKUP_DAILY_AT:-02:30}")"
  config_set CHECK_WEEKLY_AT \
    "$(prompt_with_default "Weekly check schedule (e.g. Sun 03:30)" "${CHECK_WEEKLY_AT:-Sun 03:30}")"
  config_set SNAPSHOT_PRUNE_WEEKLY_AT \
    "$(prompt_with_default "Weekly snapshot prune schedule (e.g. Sun 04:30)" "${SNAPSHOT_PRUNE_WEEKLY_AT:-Sun 04:30}")"
  config_set BACKUP_HEARTBEAT_URL \
    "$(prompt_with_default "Backup heartbeat URL (blank to disable)" "${BACKUP_HEARTBEAT_URL:-}")"
  config_set IMAGE_AUTO_UPDATE_ENABLED \
    "$(prompt_yes_no "Enable scheduled container image refresh checks?" "${IMAGE_AUTO_UPDATE_ENABLED:-0}")"
  config_set IMAGE_AUTO_UPDATE_AT \
    "$(prompt_with_default "Daily image refresh check time (HH:MM)" "${IMAGE_AUTO_UPDATE_AT:-05:15}")"
  config_set IMAGE_AUTO_UPDATE_RANDOMIZED_DELAY \
    "$(prompt_with_default "Randomized delay for image refresh timer" "${IMAGE_AUTO_UPDATE_RANDOMIZED_DELAY:-30m}")"
  config_set HOST_PACKAGE_AUTO_UPDATE_ENABLED \
    "$(prompt_yes_no "Enable scheduled host package upgrades (Docker, compose, tailscale, restic)?" "${HOST_PACKAGE_AUTO_UPDATE_ENABLED:-0}")"
  config_set HOST_PACKAGE_AUTO_UPDATE_AT \
    "$(prompt_with_default "Weekly host upgrade schedule (e.g. Mon 05:45)" "${HOST_PACKAGE_AUTO_UPDATE_AT:-Mon 05:45}")"
  config_set HOST_PACKAGE_AUTO_UPDATE_RANDOMIZED_DELAY \
    "$(prompt_with_default "Randomized delay for host upgrade timer" "${HOST_PACKAGE_AUTO_UPDATE_RANDOMIZED_DELAY:-45m}")"
  local host_auto_reboot_enabled
  host_auto_reboot_enabled="$(prompt_yes_no "Enable auto-reboot after kernel updates during a maintenance window?" "${HOST_AUTO_REBOOT_ENABLED:-0}")"
  config_set HOST_AUTO_REBOOT_ENABLED "$host_auto_reboot_enabled"
  if [[ "$host_auto_reboot_enabled" == "1" ]]; then
    config_set HOST_AUTO_REBOOT_WINDOW_START \
      "$(prompt_with_default "Maintenance window start (HH:MM)" "${HOST_AUTO_REBOOT_WINDOW_START:-03:00}")"
    config_set HOST_AUTO_REBOOT_WINDOW_END \
      "$(prompt_with_default "Maintenance window end (HH:MM)" "${HOST_AUTO_REBOOT_WINDOW_END:-05:00}")"
  fi

  echo
  config_set BACKUP_TARGETS "nas cloud archive"
  configure_backup_target nas
  configure_backup_target cloud
  configure_backup_target archive

  ensure_cfg_file
  load_cfg
  export_env_for_compose
  configure_service_secrets

  ensure_cfg_file
  load_cfg
  sync_timer_overrides

  echo
  echo "[domum-media] Configuration saved to $CFG_FILE"
  echo "[domum-media] Timer overrides synced. Run 'sudo domum-media apply' to converge services."
}

tracked_service_container_id() {
  local svc="$1"
  compose_cmd ps -q "$svc" 2>/dev/null | head -n 1
}

tracked_service_image_id() {
  local svc="$1"
  local cid
  cid="$(tracked_service_container_id "$svc")"
  [[ -n "$cid" ]] || return 0
  docker inspect --format '{{.Image}}' "$cid" 2>/dev/null || true
}

write_update_state() {
  local path="$1"
  local image_id="$2"
  local first_seen="$3"
  local last_update_ts="${4:-}"
  local last_update_from="${5:-}"
  local last_update_to="${6:-}"
  local last_update_snapshot="${7:-}"
  write_env_kv "$path" \
    SEEN_IMAGE_ID "$image_id" \
    FIRST_SEEN_TS "$first_seen" \
    CANDIDATE_DIGEST "$image_id" \
    LAST_UPDATE_TS "$last_update_ts" \
    LAST_UPDATE_FROM "$last_update_from" \
    LAST_UPDATE_TO "$last_update_to" \
    LAST_UPDATE_SNAPSHOT "$last_update_snapshot"
}

clear_update_candidate_state() {
  local path="$1"
  rm -f "$path"
}

refresh_images() {
  need_root
  load_cfg
  export_env_for_compose
  ensure_dirs
  local force=0
  local check_only=0
  local apply_now=0

  while (( $# )); do
    case "$1" in
      --force) force=1 ;;
      --check-only) check_only=1 ;;
      --apply-now) apply_now=1 ;;
      *) die "Usage: domum-media refresh-images [--force] [--check-only] [--apply-now]" ;;
    esac
    shift
  done

  if (( force == 0 && check_only == 0 && apply_now == 0 )) && [[ "${IMAGE_AUTO_UPDATE_ENABLED:-0}" != "1" ]]; then
    echo "[domum-media] Scheduled image refresh disabled (IMAGE_AUTO_UPDATE_ENABLED=0)."
    return 0
  fi

  local due_services=()
  local any_due=0
  local now
  now="$(date +%s)"

  while IFS='|' read -r key enable_var image_var auto_var delay_var svc; do
    [[ "${!enable_var:-0}" == "1" ]] || continue
    [[ "${!auto_var:-0}" == "1" ]] || continue

    local image_ref running_id current_id state_file delay_days delay_secs first_seen_ts remaining previous_candidate previous_seen
    image_ref="${!image_var:-}"
    [[ -n "$image_ref" ]] || continue

    echo "[domum-media] Checking ${key} -> ${image_ref}"
    compose_cmd pull "$svc" >/dev/null

    running_id="$(tracked_service_image_id "$svc")"
    current_id="$(docker image inspect "$image_ref" --format '{{.Id}}' 2>/dev/null || true)"
    state_file="$DOMUM_STATE_ROOT/image-updates/${key}.env"
    delay_days="${!delay_var:-7}"
    delay_secs=$(( delay_days * 86400 ))

    if [[ -z "$running_id" || -z "$current_id" ]]; then
      clear_update_candidate_state "$state_file"
      echo "[domum-media] Skipping ${key}; container or image metadata unavailable."
      continue
    fi

    if [[ "$running_id" == "$current_id" ]]; then
      clear_update_candidate_state "$state_file"
      echo "[domum-media] ${key} already running the current image."
      continue
    fi

    unset SEEN_IMAGE_ID FIRST_SEEN_TS CANDIDATE_DIGEST LAST_UPDATE_TS LAST_UPDATE_FROM LAST_UPDATE_TO LAST_UPDATE_SNAPSHOT
    if [[ -f "$state_file" ]]; then
      # shellcheck disable=SC1090
      source "$state_file"
    fi

    previous_candidate="${CANDIDATE_DIGEST:-${SEEN_IMAGE_ID:-}}"
    previous_seen="${FIRST_SEEN_TS:-$now}"

    if [[ -z "$previous_candidate" ]]; then
      write_update_state "$state_file" "$current_id" "$now" "${LAST_UPDATE_TS:-}" "${LAST_UPDATE_FROM:-}" "${LAST_UPDATE_TO:-}" "${LAST_UPDATE_SNAPSHOT:-}"
      if (( apply_now == 1 )); then
        due_services+=("${key}|${svc}|${running_id}|${current_id}|${state_file}")
        any_due=1
        continue
      fi
      echo "[domum-media] ${key} has a newer image; waiting ${delay_days} day(s) before rollout."
      continue
    fi

    if [[ "$previous_candidate" != "$current_id" ]]; then
      write_update_state "$state_file" "$current_id" "$now" "${LAST_UPDATE_TS:-}" "${LAST_UPDATE_FROM:-}" "${LAST_UPDATE_TO:-}" "${LAST_UPDATE_SNAPSHOT:-}"
      record_update_history "$key" "delay_reset" "$previous_candidate" "$current_id" "" "success" "upstream moved during delay window"
      if (( apply_now == 1 )); then
        due_services+=("${key}|${svc}|${running_id}|${current_id}|${state_file}")
        any_due=1
        continue
      fi
      echo "[domum-media] ${key} upstream moved during delay window; restarting the ${delay_days}-day timer."
      continue
    fi

    first_seen_ts="$previous_seen"
    if (( apply_now == 0 )) && (( now - first_seen_ts < delay_secs )); then
      remaining=$(( delay_secs - (now - first_seen_ts) ))
      echo "[domum-media] ${key} is still in the delay window (${remaining}s remaining)."
      continue
    fi

    if (( check_only == 1 )); then
      echo "[domum-media] ${key} is ready to update (${image_ref})."
      any_due=1
      continue
    fi

    due_services+=("${key}|${svc}|${running_id}|${current_id}|${state_file}")
    any_due=1
  done < <(managed_image_specs)

  if (( any_due == 0 )); then
    if (( check_only == 1 )); then
      echo "[domum-media] No tracked images are ready."
    else
      echo "[domum-media] No tracked images are ready to roll out."
    fi
    return 0
  fi

  if (( check_only == 1 )); then
    return 0
  fi

  local entry logical_service before_image after_image version_key before_version snapshot_name state_file compose_svcs
  for entry in "${due_services[@]}"; do
    IFS='|' read -r logical_service _ before_image after_image state_file <<< "$entry"
    verify_backup_freshness "$logical_service"
    version_key="$(printf '%s_IMAGE' "$(uppercase_token "$logical_service")")"
    before_version="$(service_configured_version "$version_key")"
    snapshot_name="$(create_service_snapshot "$logical_service" "pre-update" "$before_image" "$after_image" || true)"
    compose_svcs="$(service_compose_services "$logical_service" || true)"
    [[ -n "$compose_svcs" ]] || continue
    echo "[domum-media] Updating $logical_service (${compose_svcs})"
    # shellcheck disable=SC2086
    compose_cmd up -d $compose_svcs
    if ! wait_for_service_health "$logical_service" 120 5; then
      echo "[domum-media] Health validation failed for $logical_service"
      record_update_history "$logical_service" "skipped_unhealthy" "$before_image" "$after_image" "$snapshot_name" "failure" "automatic rollback triggered"
      if [[ "${AUTO_ROLLBACK_ENABLED:-1}" == "1" && -n "$snapshot_name" ]]; then
        restore_snapshot_for_service "$logical_service" "$snapshot_name"
        record_update_history "$logical_service" "rolled_back" "$after_image" "$before_image" "$snapshot_name" "success" "restored after failed health validation"
      fi
      if [[ "${AUTO_ROLLBACK_ENABLED:-1}" == "1" && -n "$snapshot_name" ]]; then
        die "Update aborted: $logical_service failed health validation and was rolled back."
      fi
      die "Update aborted: $logical_service failed health validation."
    fi
    clear_update_candidate_state "$state_file"
    record_update_history "$logical_service" "applied" "$before_image" "$after_image" "$snapshot_name" "success" "$before_version -> ${!version_key:-unknown}"
    if [[ "${CLEANUP_IMAGES_AFTER_UPDATE:-1}" == "1" ]]; then
      cleanup_images_execute 1 0 >/dev/null 2>&1 || true
    fi
  done
  echo "[domum-media] Image refresh done."
}

time_hhmm_to_minutes() {
  local value="$1"
  printf '%s' $(( 10#${value%:*} * 60 + 10#${value#*:} ))
}

within_reboot_window() {
  local now_hhmm start end now_m start_m end_m
  now_hhmm="$(date +%H:%M)"
  start="${HOST_AUTO_REBOOT_WINDOW_START:-03:00}"
  end="${HOST_AUTO_REBOOT_WINDOW_END:-05:00}"
  now_m="$(time_hhmm_to_minutes "$now_hhmm")"
  start_m="$(time_hhmm_to_minutes "$start")"
  end_m="$(time_hhmm_to_minutes "$end")"

  if (( start_m <= end_m )); then
    (( now_m >= start_m && now_m <= end_m ))
  else
    (( now_m >= start_m || now_m <= end_m ))
  fi
}

host_upgrade() {
  need_root
  load_cfg
  export_env_for_compose
  local force=0
  [[ "${1:-}" == "--force" ]] && force=1

  if (( force == 0 )) && [[ "${HOST_PACKAGE_AUTO_UPDATE_ENABLED:-0}" != "1" ]]; then
    echo "[domum-media] Scheduled host package upgrades disabled (HOST_PACKAGE_AUTO_UPDATE_ENABLED=0)."
    return 0
  fi

  echo "[domum-media] Updating host packages from configured apt repos..."
  export DEBIAN_FRONTEND=noninteractive
  apt-get update -y
  apt-get install -y --only-upgrade \
    docker-ce docker-ce-cli containerd.io docker-buildx-plugin docker-compose-plugin \
    tailscale restic btrfs-progs jq apparmor nfs-common rclone gettext-base \
    unattended-upgrades apt-listchanges age
  record_update_history "host" "applied" "" "" "" "success" "apt host-upgrade completed"
  if [[ -f /var/run/reboot-required ]]; then
    echo "[domum-media] Reboot required by the latest package upgrade."
    if [[ "${HOST_AUTO_REBOOT_ENABLED:-0}" == "1" ]] && within_reboot_window; then
      echo "[domum-media] Auto-reboot window open; rebooting now."
      shutdown -r +1 "domum-media host-upgrade requested reboot"
    fi
  fi
  echo "[domum-media] Host package upgrade done."
}

show_update_inventory() {
  need_root
  load_cfg
  export_env_for_compose

  printf '%-14s %-5s %-5s %-8s %-24s\n' "SERVICE" "CLASS" "AUTO" "DELAY" "CURRENT"
  while IFS='|' read -r name enable_var class default_delay _ image_var _; do
    [[ "${!enable_var:-0}" == "1" ]] || continue
    local auto_var delay_var auto_value delay_value
    if [[ "$name" == "immich" ]]; then
      auto_value="${IMMICH_BUNDLE_AUTO_UPDATE:-0}"
      delay_value="${IMMICH_BUNDLE_DELAY_DAYS:-$default_delay}"
    else
      auto_var="$(printf '%s_AUTO_UPDATE' "$(uppercase_token "$name")")"
      delay_var="$(printf '%s_AUTO_UPDATE_DELAY_DAYS' "$(uppercase_token "$name")")"
      auto_value="${!auto_var:-0}"
      delay_value="${!delay_var:-$default_delay}"
    fi
    printf '%-14s %-5s %-5s %-8s %-24s\n' \
      "$name" "$class" "$auto_value" "${delay_value}d" "$(service_configured_version "$image_var")"
  done < <(service_lifecycle_specs)

  if [[ -f "$DOMUM_STATE_ROOT/immich/bundle-candidate.env" ]]; then
    echo
    echo "Immich bundle candidate:"
    # shellcheck disable=SC1090
    # shellcheck disable=SC1091
    source "$DOMUM_STATE_ROOT/immich/bundle-candidate.env"
    printf '  release=%s published=%s\n' "${IMMICH_BUNDLE_TAG:-unknown}" "${IMMICH_BUNDLE_PUBLISHED_AT:-unknown}"
    printf '  server=%s\n' "${IMMICH_BUNDLE_SERVER_IMAGE:-unknown}"
    printf '  ml=%s\n' "${IMMICH_BUNDLE_MACHINE_LEARNING_IMAGE:-unknown}"
    printf '  redis=%s\n' "${IMMICH_BUNDLE_REDIS_IMAGE:-unknown}"
    printf '  postgres=%s\n' "${IMMICH_BUNDLE_POSTGRES_IMAGE:-unknown}"
  fi
}

updates_history() {
  load_cfg
  ensure_state_dirs

  printf '%-19s %-14s %-18s %-8s %s\n' "WHEN" "SERVICE" "EVENT" "RESULT" "NOTE"
  find "$(update_history_dir)" -type f -name '*.env' | sort | while IFS= read -r file; do
    unset SERVICE EVENT RESULT NOTE TS
    # shellcheck disable=SC1090
    source "$file"
    printf '%-19s %-14s %-18s %-8s %s\n' \
      "$(epoch_to_iso "${TS:-0}")" \
      "${SERVICE:-unknown}" \
      "${EVENT:-unknown}" \
      "${RESULT:-unknown}" \
      "${NOTE:-}"
  done
}

updates_cmd() {
  load_cfg
  export_env_for_compose
  local sub="${1:-summary}"
  case "$sub" in
    ""|summary) show_update_inventory ;;
    check) shift; show_update_inventory; echo; refresh_images --check-only; [[ "${ENABLE_IMMICH:-0}" == "1" ]] && immich_refresh_bundle --check-only ;;
    apply) shift; refresh_images --apply-now --force; [[ "${ENABLE_IMMICH:-0}" == "1" ]] && immich_refresh_bundle --force ;;
    history) shift; updates_history ;;
    *) die "Usage: domum-media updates {summary|check|apply|history}" ;;
  esac
}

immich_extract_image() {
  local compose_file="$1"
  local pattern="$2"
  awk -v pattern="$pattern" '
    $0 ~ pattern { capture=1 }
    capture && $1 == "image:" { print $2; exit }
    capture && NF == 0 { capture=0 }
  ' "$compose_file"
}

immich_refresh_bundle() {
  need_root
  load_cfg
  export_env_for_compose
  ensure_dirs

  local force=0
  local check_only=0
  while (( $# )); do
    case "$1" in
      --force) force=1 ;;
      --check-only) check_only=1 ;;
      *) die "Usage: domum-media immich {refresh-bundle [--force]|check-bundle|apply-bundle|rollback}" ;;
    esac
    shift
  done

  cmd_exists curl || die "curl is required for immich bundle refresh"
  cmd_exists jq || die "jq is required for immich bundle refresh"

  local api_url="https://api.github.com/repos/immich-app/immich/releases/latest"
  local release_json compose_tmp meta_tmp candidate_file applied_file
  release_json="$(mktemp)"
  compose_tmp="$(mktemp)"
  meta_tmp="$(mktemp)"
  candidate_file="$DOMUM_STATE_ROOT/immich/bundle-candidate.env"
  applied_file="$DOMUM_STATE_ROOT/immich/applied-bundle.env"

  curl -fsSL "$api_url" > "$release_json"
  curl -fsSL "https://github.com/immich-app/immich/releases/latest/download/docker-compose.yml" > "$compose_tmp"

  jq -r '{
    tag_name,
    html_url,
    published_at
  } | to_entries[] | "\(.key)=\(.value)"' "$release_json" > "$meta_tmp"

  local tag_name html_url published_at server_image ml_image redis_image postgres_image
  tag_name="$(awk -F= '$1=="tag_name" {print $2}' "$meta_tmp")"
  html_url="$(awk -F= '$1=="html_url" {print $2}' "$meta_tmp")"
  published_at="$(awk -F= '$1=="published_at" {print $2}' "$meta_tmp")"
  server_image="$(immich_extract_image "$compose_tmp" "container_name:[[:space:]]*immich_server")"
  ml_image="$(immich_extract_image "$compose_tmp" "container_name:[[:space:]]*immich_machine_learning")"
  redis_image="$(immich_extract_image "$compose_tmp" "container_name:[[:space:]]*immich_redis")"
  postgres_image="$(immich_extract_image "$compose_tmp" "container_name:[[:space:]]*immich_postgres")"
  [[ -n "$server_image" && -n "$ml_image" && -n "$redis_image" && -n "$postgres_image" ]] \
    || die "Failed to parse one or more Immich images from the upstream release compose file."

  local now delay_days current_bundle_key desired_bundle_key current_candidate_tag current_candidate_first_seen
  now="$(date +%s)"
  delay_days="${IMMICH_BUNDLE_DELAY_DAYS:-21}"
  current_bundle_key="${IMMICH_SERVER_IMAGE}|${IMMICH_MACHINE_LEARNING_IMAGE}|${IMMICH_REDIS_IMAGE}|${IMMICH_POSTGRES_IMAGE}"
  desired_bundle_key="${server_image}|${ml_image}|${redis_image}|${postgres_image}"

  unset IMMICH_BUNDLE_TAG IMMICH_BUNDLE_RELEASE_URL IMMICH_BUNDLE_PUBLISHED_AT IMMICH_BUNDLE_SERVER_IMAGE IMMICH_BUNDLE_MACHINE_LEARNING_IMAGE IMMICH_BUNDLE_REDIS_IMAGE IMMICH_BUNDLE_POSTGRES_IMAGE FIRST_SEEN_TS
  if [[ -f "$candidate_file" ]]; then
    # shellcheck disable=SC1090
    source "$candidate_file"
  fi
  current_candidate_tag="${IMMICH_BUNDLE_TAG:-}"
  current_candidate_first_seen="${FIRST_SEEN_TS:-$now}"

  if [[ "$current_bundle_key" == "$desired_bundle_key" ]]; then
    write_env_kv "$applied_file" \
      RELEASE_TAG "$tag_name" \
      RELEASE_URL "$html_url" \
      RELEASE_DATE "$published_at" \
      FIRST_APPLIED_TS "$now" \
      SERVER_IMAGE "$server_image" \
      ML_IMAGE "$ml_image" \
      REDIS_IMAGE "$redis_image" \
      POSTGRES_IMAGE "$postgres_image"
    rm -f "$candidate_file"
    echo "[domum-media] Immich already matches the latest release bundle ($tag_name)."
    rm -f "$release_json" "$compose_tmp" "$meta_tmp"
    return 0
  fi

  if [[ "$current_candidate_tag" != "$tag_name" ]]; then
    write_env_kv "$candidate_file" \
      IMMICH_BUNDLE_TAG "$tag_name" \
      IMMICH_BUNDLE_RELEASE_URL "$html_url" \
      IMMICH_BUNDLE_PUBLISHED_AT "$published_at" \
      IMMICH_BUNDLE_SERVER_IMAGE "$server_image" \
      IMMICH_BUNDLE_MACHINE_LEARNING_IMAGE "$ml_image" \
      IMMICH_BUNDLE_REDIS_IMAGE "$redis_image" \
      IMMICH_BUNDLE_POSTGRES_IMAGE "$postgres_image" \
      FIRST_SEEN_TS "$now"
    if [[ -n "$current_candidate_tag" ]]; then
      record_update_history "immich" "delay_reset" "$current_candidate_tag" "$tag_name" "" "success" "newer bundle appeared during delay window"
      echo "[domum-media] Immich bundle advanced from $current_candidate_tag to $tag_name; delay restarted."
    else
      echo "[domum-media] Stored new Immich bundle candidate $tag_name; waiting ${delay_days} day(s)."
    fi
    if (( force == 0 )); then
      rm -f "$release_json" "$compose_tmp" "$meta_tmp"
      return 0
    fi
  fi

  local remaining
  if (( force == 0 )) && (( check_only == 0 )) && [[ "${IMMICH_BUNDLE_AUTO_UPDATE:-1}" != "1" ]]; then
    echo "[domum-media] Immich bundle auto-update is disabled."
    rm -f "$release_json" "$compose_tmp" "$meta_tmp"
    return 0
  fi
  if (( force == 0 )) && (( now - current_candidate_first_seen < delay_days * 86400 )); then
    remaining=$(( delay_days * 86400 - (now - current_candidate_first_seen) ))
    echo "[domum-media] Immich bundle $tag_name is still in the delay window (${remaining}s remaining)."
    rm -f "$release_json" "$compose_tmp" "$meta_tmp"
    return 0
  fi
  if (( check_only == 1 )); then
    echo "[domum-media] Immich bundle $tag_name is ready."
    rm -f "$release_json" "$compose_tmp" "$meta_tmp"
    return 0
  fi

  verify_backup_freshness immich

  local old_server="$IMMICH_SERVER_IMAGE"
  local old_ml="$IMMICH_MACHINE_LEARNING_IMAGE"
  local old_redis="$IMMICH_REDIS_IMAGE"
  local old_postgres="$IMMICH_POSTGRES_IMAGE"
  local snapshot_name
  snapshot_name="$(create_service_snapshot immich "pre-immich-bundle" "$old_server" "$server_image" || true)"

  config_set IMMICH_SERVER_IMAGE "$server_image"
  config_set IMMICH_MACHINE_LEARNING_IMAGE "$ml_image"
  config_set IMMICH_REDIS_IMAGE "$redis_image"
  config_set IMMICH_POSTGRES_IMAGE "$postgres_image"
  load_cfg
  export_env_for_compose

  compose_cmd pull immich_server immich_machine_learning immich_redis immich_postgres
  compose_cmd up -d immich_server immich_machine_learning immich_redis immich_postgres
  if ! wait_for_service_health immich 180 5; then
    echo "[domum-media] Immich bundle rollout failed health validation."
    config_set IMMICH_SERVER_IMAGE "$old_server"
    config_set IMMICH_MACHINE_LEARNING_IMAGE "$old_ml"
    config_set IMMICH_REDIS_IMAGE "$old_redis"
    config_set IMMICH_POSTGRES_IMAGE "$old_postgres"
    load_cfg
    export_env_for_compose
    record_update_history "immich" "skipped_unhealthy" "$old_server" "$server_image" "$snapshot_name" "failure" "bundle rollout failed validation"
    if [[ -n "$snapshot_name" ]]; then
      restore_snapshot_for_service immich "$snapshot_name"
      record_update_history "immich" "rolled_back" "$server_image" "$old_server" "$snapshot_name" "success" "restored pre-bundle snapshot"
    else
      compose_cmd up -d immich_server immich_machine_learning immich_redis immich_postgres
    fi
    die "Immich bundle refresh rolled back."
  fi

  write_env_kv "$applied_file" \
    RELEASE_TAG "$tag_name" \
    RELEASE_URL "$html_url" \
    RELEASE_DATE "$published_at" \
    FIRST_APPLIED_TS "$now" \
    SERVER_IMAGE "$server_image" \
    ML_IMAGE "$ml_image" \
    REDIS_IMAGE "$redis_image" \
    POSTGRES_IMAGE "$postgres_image"
  rm -f "$candidate_file"
  record_update_history "immich" "applied" "$old_server" "$server_image" "$snapshot_name" "success" "$tag_name"
  echo "[domum-media] Immich bundle refreshed to $tag_name"
  rm -f "$release_json" "$compose_tmp" "$meta_tmp"
}

# ---- commands -------------------------------------------------------------

init_host() {
  need_root
  ensure_cfg_file
  load_cfg
  export_env_for_compose
  ensure_dirs
  converge_local_installation

  local missing=()
  if [[ "${ENABLE_TRAEFIK:-0}" == "1" ]]; then
    while IFS= read -r item; do [[ -n "$item" ]] && missing+=("$item"); done \
      < <(missing_if_absent "$SECRETS_DIR/cloudflare_api_token" "cloudflare_api_token")
    while IFS= read -r item; do [[ -n "$item" ]] && missing+=("$item"); done \
      < <(missing_if_absent "${TRAEFIK_DASHBOARD_USERS_FILE:-$SECRETS_DIR/traefik_dashboard_users}" "traefik_dashboard_users")
  fi
  if [[ "${ENABLE_IMMICH:-0}" == "1" ]]; then
    while IFS= read -r item; do [[ -n "$item" ]] && missing+=("$item"); done \
      < <(missing_if_absent "$SECRETS_DIR/immich_db_password" "immich_db_password")
    while IFS= read -r item; do [[ -n "$item" ]] && missing+=("$item"); done \
      < <(missing_if_absent "$SECRETS_DIR/immich_jwt_secret" "immich_jwt_secret")
    if immich_db_password_initialized && [[ ! -f "$(immich_db_password_fingerprint_file)" ]]; then
      echo "[domum-media] NOTE: Immich Postgres is initialized but no password fingerprint is recorded yet."
      echo "    'domum-media apply' will refuse until you restore the expected fingerprint or run:"
      echo "        sudo domum-media immich reset-db"
    fi
  fi

  while IFS= read -r target; do
    backup_target_enabled "$target" || continue
    local target_type pw_file
    target_type="$(backup_target_value "$target" TYPE repository)"
    pw_file="$(backup_target_password_file "$target")"
    [[ -f "$pw_file" ]] || missing+=("$pw_file")
    case "$target_type" in
      repository)
        if ! backup_target_has_repository_source "$target"; then
          missing+=("BACKUP_TARGET_$(uppercase_token "$target")_REPOSITORY or $(backup_target_legacy_env_file "$target")")
        fi
        local env_file
        env_file="$(backup_target_value "$target" ENV_FILE)"
        if [[ -n "$env_file" && -f "$env_file" ]]; then
          if ! validate_backup_env_file "$env_file"; then
            missing+=("invalid env file: $env_file")
          fi
        fi
        ;;
      nfs)
        [[ -n "$(backup_target_value "$target" NFS_REMOTE)" ]] || missing+=("BACKUP_TARGET_$(uppercase_token "$target")_NFS_REMOTE")
        [[ -n "$(backup_target_value "$target" NFS_MOUNT_POINT)" ]] || missing+=("BACKUP_TARGET_$(uppercase_token "$target")_NFS_MOUNT_POINT")
        [[ -n "$(backup_target_value "$target" REPOSITORY)" ]] || missing+=("BACKUP_TARGET_$(uppercase_token "$target")_REPOSITORY")
        ;;
      ftp)
        [[ -n "$(backup_target_value "$target" FTP_HOST)" ]] || missing+=("BACKUP_TARGET_$(uppercase_token "$target")_FTP_HOST")
        while IFS= read -r item; do [[ -n "$item" ]] && missing+=("$item"); done \
          < <(missing_if_absent "$(backup_target_value "$target" FTP_USERNAME_FILE "$SECRETS_DIR/${target}_ftp_username")" "FTP username file for $target")
        while IFS= read -r item; do [[ -n "$item" ]] && missing+=("$item"); done \
          < <(missing_if_absent "$(backup_target_value "$target" FTP_PASSWORD_FILE "$SECRETS_DIR/${target}_ftp_password")" "FTP password file for $target")
        ;;
    esac
  done < <(backup_target_names)

  if (( ${#missing[@]} > 0 )); then
    echo "[domum-media] WARNING: missing config/secrets:"
    for m in "${missing[@]}"; do echo "    $m"; done
    echo "    Run 'domum-media configure' or fill the listed files before the backup timer fires."
  fi

  if ! cmd_exists btrfs; then
    die "btrfs-progs not installed — rerun install.sh"
  fi
  if ! mountpoint -q "$DOMUM_DATA_ROOT"; then
    echo "[domum-media] WARNING: $DOMUM_DATA_ROOT is not a mount point."
    echo "    Did you complete docs/SETUP-N100.md? Snapshots will fail otherwise."
  fi
  if ! cmd_exists mount.nfs; then
    echo "[domum-media] WARNING: mount.nfs not found. NFS backup targets will fail until nfs-common is installed."
  fi
  if ! cmd_exists rclone; then
    echo "[domum-media] WARNING: rclone not found. FTP/rclone backup targets will fail until rclone is installed."
  fi

  sync_timer_overrides
  echo "[domum-media] init complete."
}

apply() {
  need_root
  load_cfg
  export_env_for_compose
  ensure_dirs
  converge_local_installation
  ensure_networks
  sync_timer_overrides

  sanitize_immich_secret_files

  local immich_first_boot=0
  if [[ "${ENABLE_IMMICH:-0}" == "1" ]] && ! immich_db_password_initialized; then
    immich_first_boot=1
  fi
  validate_immich_db_password_state
  validate_immich_secret_exports

  render_traefik_dynamic
  if [[ "${ENABLE_TRAEFIK:-0}" == "1" ]] && docker inspect traefik >/dev/null 2>&1; then
    echo "[domum-media] Restarting traefik to apply dynamic config..."
    docker restart traefik >/dev/null
  fi
  validate_immich_compose_config

  echo "[domum-media] Pre-apply btrfs snapshot..."
  snapshot_create "pre-apply" || echo "[domum-media] Snapshot step failed (continuing)."

  echo "[domum-media] Applying desired state..."
  compose_cmd up -d --remove-orphans

  # docker compose won't recreate a container when it sees no config change, so
  # a secret rotation can leave the old (or empty) env baked into a running
  # container. If the runtime secrets aren't consistent, force-recreate the
  # Immich services once before deciding the apply has failed.
  if [[ "${ENABLE_IMMICH:-0}" == "1" ]] && ! immich_runtime_env_ok; then
    echo "[domum-media] Immich runtime secrets inconsistent after up; force-recreating Immich services..."
    compose_cmd up -d --force-recreate \
      immich_postgres immich_redis immich_machine_learning immich_server
  fi
  validate_immich_runtime_env

  # Record the "born with" password fingerprint only on first boot and only when
  # the database actually came up cleanly — never stamp success onto a broken
  # deploy (auth-looping server / unhealthy postgres).
  if (( immich_first_boot == 1 )) && immich_db_password_initialized; then
    local pg_status server_status
    pg_status="$(container_status_summary immich_postgres)"
    server_status="$(container_status_summary immich_server)"
    if [[ "$pg_status" == "healthy" ]] \
       && [[ "$server_status" != "unhealthy" && "$server_status" != "restarting" \
             && "$server_status" != "exited" && "$server_status" != "dead" \
             && "$server_status" != "missing" ]]; then
      write_immich_db_password_fingerprint
      echo "[domum-media] Recorded Immich DB password fingerprint at $(immich_db_password_fingerprint_file)."
    else
      echo "[domum-media] WARNING: not recording Immich DB password fingerprint — immich_postgres=$pg_status immich_server=$server_status." >&2
      echo "[domum-media] Re-run 'sudo domum-media apply' once Immich is healthy, or 'sudo domum-media immich reset-db' to start clean." >&2
    fi
  fi

  echo "[domum-media] apply done."
}

status_counts() {
  local immich_lib="${DOMUM_DATA_ROOT}/immich/library"
  local media_root="${DOMUM_MEDIA_ROOT:-$MEDIA_ROOT_DEFAULT}"

  echo "=== data counts ==="
  [[ -d "$immich_lib" ]] && printf 'Immich library files: %s\n' "$(find "$immich_lib" -type f 2>/dev/null | wc -l)" || true
  if [[ -d "$media_root" ]]; then
    for subdir in movies tv music books photos; do
      [[ -d "$media_root/$subdir" ]] || continue
      printf '%s files: %s\n' "$subdir" "$(find "$media_root/$subdir" -type f 2>/dev/null | wc -l)"
    done
  fi
}

status_storage() {
  echo "=== storage ==="
  echo "  $DOMUM_DATA_ROOT   = durable / protected disk (snapshotted + backed up)"
  echo "  $DOMUM_MEDIA_ROOT  = disposable media on the OS disk (not backed up by default)"
  printf '%-28s %-8s %-8s %-8s %-6s\n' "PATH" "SIZE" "USED" "AVAIL" "USE%"
  for path in "$DOMUM_DATA_ROOT" "$DOMUM_MEDIA_ROOT" "$DOMUM_SNAPSHOT_ROOT" /; do
    [[ -e "$path" ]] || continue
    df -h --output=target,size,used,avail,pcent "$path" 2>/dev/null | tail -n1
  done | awk '{printf "%-28s %-8s %-8s %-8s %-6s\n",$1,$2,$3,$4,$5}'
}

status() {
  need_root
  load_cfg
  export_env_for_compose
  ensure_networks
  local show_counts=0
  [[ "${1:-}" == "--counts" ]] && show_counts=1

  echo "=== compose ps ==="
  compose_cmd ps || true

  echo
  echo "=== restic last snapshots ==="
  "$DOMUM_DIR/bin/domum-media-backup" --snapshots || true

  echo
  echo "=== btrfs snapshots (${DOMUM_SNAPSHOT_ROOT}) ==="
  snapshot_list

  echo
  status_storage

  if (( show_counts == 1 )); then
    echo
    status_counts
  fi
}

repo_update() {
  need_root
  echo "[domum-media] git fetch + reset --hard origin/main in $DOMUM_DIR..."
  [[ -d "$DOMUM_DIR/.git" ]] || die "$DOMUM_DIR is not a git repo — reinstall via install.sh"
  git -C "$DOMUM_DIR" fetch --all --prune
  git -C "$DOMUM_DIR" reset --hard origin/main
  converge_local_installation
  exec /usr/local/bin/domum-media apply
}

logs_cmd() {
  need_root
  load_cfg
  export_env_for_compose
  local svc="${1:-}"
  [[ -n "$svc" ]] || die "Usage: domum-media logs <service>"
  compose_cmd logs -f --tail=200 "$svc"
}

backup_cmd() {
  need_root
  shift || true
  exec /usr/local/bin/domum-media-backup "$@"
}

snapshot_cmd() {
  need_root
  load_cfg
  local sub="${1:-}"
  case "$sub" in
    create) shift; snapshot_create "${1:-manual}" ;;
    list)   snapshot_list ;;
    prune)  snapshot_prune ;;
    *) die "Usage: domum-media snapshot {create [tag]|list|prune}" ;;
  esac
}

rollback_entries() {
  find "$(rollback_index_dir)" -type f -name '*.env' | sort
}

rollback_list_cmd() {
  printf '%-28s %-12s %-18s %-10s %-10s\n' "ID" "SERVICE" "EVENT" "AGE" "STATUS"
  rollback_entries | while IFS= read -r file; do
    unset ID SERVICE EVENT TS STATUS
    # shellcheck disable=SC1090
    source "$file"
    printf '%-28s %-12s %-18s %-10s %-10s\n' \
      "${ID:-unknown}" \
      "${SERVICE:-unknown}" \
      "${EVENT:-unknown}" \
      "$(human_age_from_epoch "${TS:-0}")" \
      "${STATUS:-unknown}"
  done
}

rollback_show_cmd() {
  local rollback_id="$1"
  local file
  file="$(rollback_index_dir)/${rollback_id}.env"
  [[ -f "$file" ]] || die "Rollback point not found: $rollback_id"
  cat "$file"
}

rollback_apply_entry() {
  local rollback_id="$1"
  local dry_run="${2:-0}"
  local file snapshot_name
  file="$(rollback_index_dir)/${rollback_id}.env"
  [[ -f "$file" ]] || die "Rollback point not found: $rollback_id"

  unset ID SERVICE EVENT SNAPSHOT SNAPSHOT_NAME IMAGE_BEFORE IMAGE_AFTER TS STATUS
  # shellcheck disable=SC1090
  source "$file"
  [[ "${STATUS:-available}" == "available" ]] || die "Rollback point is not available: ${STATUS:-unknown}"
  snapshot_name="${SNAPSHOT_NAME:-$(basename "${SNAPSHOT:-}")}"
  [[ -n "$snapshot_name" ]] || die "Rollback point $rollback_id has no snapshot path."

  if (( dry_run == 1 )); then
    echo "[domum-media] Would restore ${SERVICE:-unknown} from ${snapshot_name}"
    return 0
  fi

  restore_snapshot_for_service "${SERVICE:-unknown}" "$snapshot_name"
  update_rollback_entry_status "$file" "consumed"
  record_update_history "${SERVICE:-unknown}" "rolled_back" "${IMAGE_AFTER:-}" "${IMAGE_BEFORE:-}" "$snapshot_name" "success" "manual rollback apply ${rollback_id}"
}

rollback_cmd() {
  need_root
  load_cfg
  export_env_for_compose
  ensure_state_dirs

  local sub="${1:-interactive}"
  case "$sub" in
    list) rollback_list_cmd ;;
    show) shift; [[ -n "${1:-}" ]] || die "Usage: domum-media rollback show <id>"; rollback_show_cmd "$1" ;;
    apply)
      shift
      [[ -n "${1:-}" ]] || die "Usage: domum-media rollback apply <id> [--dry-run]"
      local rollback_id="$1"
      local dry_run=0
      shift || true
      [[ "${1:-}" == "--dry-run" ]] && dry_run=1
      rollback_apply_entry "$rollback_id" "$dry_run"
      ;;
    interactive)
      local snapshots=()
      local idx=1
      while IFS= read -r file; do
        [[ -n "$file" ]] || continue
        unset ID SERVICE EVENT STATUS
        # shellcheck disable=SC1090
        source "$file"
        [[ "${STATUS:-available}" == "available" ]] || continue
        snapshots+=("${ID}")
        printf '%d) %s | %s | %s\n' "$idx" "${ID}" "${SERVICE:-unknown}" "${EVENT:-unknown}"
        idx=$(( idx + 1 ))
      done < <(rollback_entries)
      (( ${#snapshots[@]} > 0 )) || die "No rollback points available."
      local choice selected
      read -r -p "Select rollback number to restore: " choice
      [[ "$choice" =~ ^[0-9]+$ ]] || die "Invalid selection."
      selected="${snapshots[$((choice - 1))]:-}"
      [[ -n "$selected" ]] || die "Selection out of range."
      rollback_apply_entry "$selected" 0
      ;;
    *) die "Usage: domum-media rollback {list|show <id>|apply <id> [--dry-run]}" ;;
  esac
}

image_ids_used_by_any_container() {
  docker ps -aq 2>/dev/null | while IFS= read -r cid; do
    [[ -n "$cid" ]] || continue
    docker inspect --format '{{.Image}}' "$cid" 2>/dev/null || true
  done | sort -u
}

collect_cleanup_image_ids() {
  local tmp
  tmp="$(mktemp)"
  image_ids_used_by_any_container > "$tmp"

  {
    docker images --filter dangling=true -q 2>/dev/null || true
    rollback_entries | while IFS= read -r file; do
      unset IMAGE_BEFORE IMAGE_AFTER
      # shellcheck disable=SC1090
      source "$file"
      [[ -n "${IMAGE_BEFORE:-}" ]] && printf '%s\n' "$IMAGE_BEFORE"
      [[ -n "${IMAGE_AFTER:-}" ]] && printf '%s\n' "$IMAGE_AFTER"
    done
  } | sort -u | while IFS= read -r image_id; do
    [[ -n "$image_id" ]] || continue
    docker image inspect "$image_id" >/dev/null 2>&1 || continue
    grep -Fxq "$image_id" "$tmp" && continue
    printf '%s\n' "$image_id"
  done

  rm -f "$tmp"
}

cleanup_images_execute() {
  local dry_run="${1:-1}"
  local confirm="${2:-0}"
  local -a ids=()
  local total_size=0
  local size

  while IFS= read -r id; do
    [[ -n "$id" ]] || continue
    ids+=("$id")
  done < <(collect_cleanup_image_ids)

  if (( ${#ids[@]} == 0 )); then
    echo "[domum-media] No pruneable images found."
    return 0
  fi

  for id in "${ids[@]}"; do
    size="$(docker image inspect "$id" --format '{{.Size}}' 2>/dev/null || echo 0)"
    total_size=$(( total_size + size ))
    printf '%s %s\n' "$id" "$(docker image inspect "$id" --format '{{.RepoTags}}' 2>/dev/null || echo '[]')"
  done
  echo "[domum-media] Candidate image count: ${#ids[@]} (approx $(( total_size / 1024 / 1024 )) MiB)"

  if (( dry_run == 1 )); then
    return 0
  fi

  if (( confirm == 0 )); then
    die "Refusing destructive cleanup without --confirm"
  fi

  docker image rm "${ids[@]}"
}

cleanup_snapshot_candidates() {
  local keep="${CLEANUP_OLD_SNAPSHOTS_KEEP:-${SNAPSHOT_KEEP_PER_SUBVOL:-14}}"
  local names base total drop i
  [[ -d "$DOMUM_SNAPSHOT_ROOT" ]] || return 0
  names="$(find "$DOMUM_SNAPSHOT_ROOT" -mindepth 1 -maxdepth 1 -printf '%f\n' 2>/dev/null | sed -E 's/-[0-9]{8}-[0-9]{6}-.*$//' | sort -u || true)"
  while IFS= read -r base; do
    [[ -n "$base" ]] || continue
    mapfile -t snaps < <(list_snapshots_for_base "$base")
    total="${#snaps[@]}"
    drop=$(( total - keep ))
    if (( drop > 0 )); then
      for (( i = 0; i < drop; i++ )); do
        printf '%s\n' "${snaps[$i]}"
      done
    fi
  done <<< "$names"
}

cleanup_snapshots_execute() {
  local dry_run="${1:-1}"
  local confirm="${2:-0}"
  local -a victims=()
  while IFS= read -r snap; do
    [[ -n "$snap" ]] || continue
    victims+=("$snap")
  done < <(cleanup_snapshot_candidates)

  if (( ${#victims[@]} == 0 )); then
    echo "[domum-media] No pruneable snapshots found."
    return 0
  fi

  printf '%s\n' "${victims[@]}"
  if (( dry_run == 1 )); then
    return 0
  fi
  if (( confirm == 0 )); then
    die "Refusing destructive cleanup without --confirm"
  fi
  local victim
  for victim in "${victims[@]}"; do
    btrfs subvolume delete "$DOMUM_SNAPSHOT_ROOT/$victim"
  done
}

cleanup_summary() {
  local dangling exited old_snaps
  dangling="$(docker images --filter dangling=true -q 2>/dev/null | wc -l | tr -d ' ')"
  exited="$(docker ps -a --filter status=exited -q 2>/dev/null | wc -l | tr -d ' ')"
  old_snaps="$(cleanup_snapshot_candidates | wc -l | tr -d ' ')"
  echo "Cleanup summary:"
  echo "  Dangling images: $dangling"
  echo "  Exited containers: $exited"
  echo "  Snapshots beyond retention: $old_snaps"
}

cleanup_cmd() {
  need_root
  load_cfg
  export_env_for_compose
  ensure_state_dirs

  local sub="${1:-summary}"
  local dry_run=1
  local confirm=0
  shift || true
  while (( $# )); do
    case "$1" in
      --dry-run) dry_run=1 ;;
      --confirm) dry_run=0; confirm=1 ;;
      *) die "Unknown cleanup arg: $1" ;;
    esac
    shift
  done

  case "$sub" in
    summary) cleanup_summary ;;
    images) cleanup_images_execute "$dry_run" "$confirm" ;;
    snapshots) cleanup_snapshots_execute "$dry_run" "$confirm" ;;
    *) die "Usage: domum-media cleanup {summary|images|snapshots} [--dry-run|--confirm]" ;;
  esac
}

recovery_pack_manifest() {
  local stage_dir="$1"
  local manifest="$stage_dir/MANIFEST.txt"
  : > "$manifest"
  find "$stage_dir" -type f ! -name MANIFEST.txt | sort | while IFS= read -r path; do
    printf '%s  %s\n' "$(sha256_of_file "$path")" "${path#"$stage_dir"/}" >> "$manifest"
  done
}

recovery_pack_restore_instructions() {
  local stage_dir="$1"
  cat > "$stage_dir/RESTORE.txt" <<EOF
Recovery pack restore notes

1. Decrypt the archive with your age private key.
2. Restore config/domum-media.conf to $CFG_FILE
3. Restore secrets/* to $SECRETS_DIR with mode 0600 and owner root:root
4. Re-run:
   sudo domum-media configure --non-interactive
   sudo domum-media init
   sudo domum-media apply
5. Restore /srv/data from restic using domum-media-backup --restore
EOF
}

send_recovery_pack_email() {
  local archive="$1"
  local smtp_user smtp_pass message
  [[ "${RECOVERY_PACK_EMAIL_ENABLED:-0}" == "1" ]] || return 0
  [[ -n "${RECOVERY_PACK_SMTP_HOST:-}" ]] || die "RECOVERY_PACK_SMTP_HOST is required when email delivery is enabled."
  [[ -f "$RECOVERY_PACK_SMTP_USERNAME_FILE" && -f "$RECOVERY_PACK_SMTP_PASSWORD_FILE" ]] || die "SMTP credential files are missing."
  smtp_user="$(read_secret_file_value "$RECOVERY_PACK_SMTP_USERNAME_FILE")"
  smtp_pass="$(read_secret_file_value "$RECOVERY_PACK_SMTP_PASSWORD_FILE")"
  message="$(mktemp)"
  {
    printf 'From: %s\n' "${RECOVERY_PACK_EMAIL_FROM:-$DOMUM_EMAIL}"
    printf 'To: %s\n' "${RECOVERY_PACK_EMAIL_TO:-$DOMUM_EMAIL}"
    printf 'Subject: domum-media recovery pack %s\n' "$(basename "$archive")"
    printf 'MIME-Version: 1.0\n'
    printf 'Content-Type: multipart/mixed; boundary="domum-boundary"\n\n'
    printf -- '--domum-boundary\n'
    printf 'Content-Type: text/plain; charset="utf-8"\n\n'
    printf 'Attached: %s\n\n' "$(basename "$archive")"
    printf -- '--domum-boundary\n'
    printf 'Content-Type: application/octet-stream; name="%s"\n' "$(basename "$archive")"
    printf 'Content-Transfer-Encoding: base64\n'
    printf 'Content-Disposition: attachment; filename="%s"\n\n' "$(basename "$archive")"
    base64 < "$archive"
    printf '\n--domum-boundary--\n'
  } > "$message"
  curl --silent --show-error --ssl-reqd \
    --url "smtps://${RECOVERY_PACK_SMTP_HOST}:${RECOVERY_PACK_SMTP_PORT}" \
    --user "${smtp_user}:${smtp_pass}" \
    --mail-from "${RECOVERY_PACK_EMAIL_FROM:-$DOMUM_EMAIL}" \
    --mail-rcpt "${RECOVERY_PACK_EMAIL_TO:-$DOMUM_EMAIL}" \
    --upload-file "$message"
  rm -f "$message"
}

recovery_pack_create() {
  [[ "${RECOVERY_PACK_ENABLED:-1}" == "1" ]] || die "Recovery pack generation is disabled (RECOVERY_PACK_ENABLED=0)."
  [[ "${RECOVERY_PACK_ENCRYPTION:-age}" == "age" ]] || die "Only age encryption is supported."
  if ! cmd_exists age; then
    echo "[domum-media] age not found — installing via apt..."
    apt-get install -y --no-install-recommends age \
      || die "age is not installed and apt-get install age failed. Install manually: apt-get install -y age"
  fi
  [[ -f "$RECOVERY_PACK_AGE_PUBKEY_FILE" ]] || die "Missing recovery pack age public key: $RECOVERY_PACK_AGE_PUBKEY_FILE"

  local no_email="${1:-0}"
  local stage_dir archive_plain archive_enc pubkey recipient ts sha size
  stage_dir="$(mktemp -d)"
  ts="$(date +%Y%m%d-%H%M%S)"
  archive_plain="$(mktemp "/tmp/recovery-pack-${ts}.XXXXXX")"
  archive_enc="$RECOVERY_PACK_DEST/recovery-pack-${ts}.tar.age"
  pubkey="$(read_secret_file_value "$RECOVERY_PACK_AGE_PUBKEY_FILE")"
  recipient="$(printf '%s' "$pubkey" | awk '/^age1/ {print; exit}')"
  [[ -n "$recipient" ]] || die "Could not parse age recipient from $RECOVERY_PACK_AGE_PUBKEY_FILE"

  mkdir -p "$stage_dir/config" "$stage_dir/secrets" "$stage_dir/meta"
  [[ -f "$CFG_FILE" ]] && install -m 0600 "$CFG_FILE" "$stage_dir/config/domum-media.conf"
  find "$SECRETS_DIR" -maxdepth 1 -type f 2>/dev/null | while IFS= read -r file; do
    install -m 0600 "$file" "$stage_dir/secrets/$(basename "$file")"
  done
  git -C "$DOMUM_DIR" rev-parse HEAD > "$stage_dir/meta/git-revision.txt" 2>/dev/null || true
  compose_cmd config > "$stage_dir/meta/rendered-compose.yml" 2>/dev/null || true
  recovery_pack_restore_instructions "$stage_dir"
  recovery_pack_manifest "$stage_dir"

  tar -C "$stage_dir" -czf "$archive_plain" .
  age -r "$recipient" -o "$archive_enc" "$archive_plain"
  sha="$(sha256_of_file "$archive_enc")"
  size="$(stat -c %s "$archive_enc" 2>/dev/null || stat -f %z "$archive_enc")"
  write_env_kv "$(recovery_pack_state_file)" \
    ARCHIVE_PATH "$archive_enc" \
    SHA256 "$sha" \
    SIZE "$size" \
    TS "$(date +%s)" \
    VERIFIED_TS "$(date +%s)"
  rm -rf "$stage_dir"
  rm -f "$archive_plain"

  if (( no_email == 0 )); then
    send_recovery_pack_email "$archive_enc"
  fi

  echo "[domum-media] Recovery pack written to $archive_enc"
}

recovery_pack_status() {
  local state_file archive_path ts size sha
  state_file="$(recovery_pack_state_file)"
  if [[ ! -f "$state_file" ]]; then
    echo "[domum-media] No recovery pack has been created yet."
    return 1
  fi
  unset ARCHIVE_PATH SHA256 SIZE TS VERIFIED_TS
  # shellcheck disable=SC1090
  source "$state_file"
  archive_path="${ARCHIVE_PATH:-}"
  ts="${TS:-0}"
  size="${SIZE:-0}"
  sha="${SHA256:-}"
  echo "Recovery pack:"
  echo "  path: ${archive_path:-missing}"
  echo "  age: $(human_age_from_epoch "$ts")"
  echo "  size: ${size} bytes"
  echo "  sha256: ${sha:-unknown}"
  echo "  verified age: $(human_age_from_epoch "${VERIFIED_TS:-$ts}")"
}

recovery_pack_cmd() {
  need_root
  load_cfg
  export_env_for_compose
  ensure_state_dirs

  local sub="${1:-create}"
  case "$sub" in
    create)
      shift || true
      local no_email=0
      [[ "${1:-}" == "--no-email" ]] && no_email=1
      recovery_pack_create "$no_email"
      ;;
    status) recovery_pack_status ;;
    *) die "Usage: domum-media recovery-pack {create [--no-email]|status}" ;;
  esac
}

json_array_from_items() {
  if (( $# == 0 )); then
    printf '[]'
  else
    printf '%s\n' "$@" | jq -R . | jq -s .
  fi
}

checkup_add() {
  local level="$1"
  shift
  case "$level" in
    critical) CHECKUP_CRITICAL+=("$*") ;;
    warning) CHECKUP_WARNINGS+=("$*") ;;
    healthy) CHECKUP_HEALTHY+=("$*") ;;
    action) CHECKUP_ACTIONS+=("$*") ;;
  esac
}

checkup_cmd() {
  need_root
  load_cfg
  export_env_for_compose
  ensure_state_dirs

  local json=0
  [[ "${1:-}" == "--json" ]] && json=1

  CHECKUP_CRITICAL=()
  CHECKUP_WARNINGS=()
  CHECKUP_HEALTHY=()
  CHECKUP_ACTIONS=()

  [[ -n "${DOMUM_DOMAIN:-}" ]] || checkup_add critical "DOMUM_DOMAIN is empty."
  [[ -n "${BACKUP_POLICY:-}" ]] || checkup_add critical "BACKUP_POLICY is unset."
  case "${BACKUP_POLICY^^}" in
    STRICT|BALANCED|LENIENT) ;;
    *) checkup_add critical "BACKUP_POLICY must be STRICT, BALANCED, or LENIENT." ;;
  esac
  if grep -qE '^(IMMICH_VERSION|JELLYFIN_VERSION|NAVIDROME_VERSION)=' "$CFG_FILE" 2>/dev/null; then
    checkup_add critical "Legacy image pin variables are still present in the config."
  fi
  if ! enabled_backup_targets | grep -q .; then
    checkup_add critical "No backup targets are enabled."
  else
    checkup_add healthy "At least one backup target is enabled."
  fi

  local required_secret
  for required_secret in \
    $([[ "${ENABLE_TRAEFIK:-0}" == "1" ]] && printf '%s ' "$SECRETS_DIR/cloudflare_api_token" "${TRAEFIK_DASHBOARD_USERS_FILE:-$SECRETS_DIR/traefik_dashboard_users}") \
    $([[ "${ENABLE_IMMICH:-0}" == "1" ]] && printf '%s ' "$SECRETS_DIR/immich_db_password" "$SECRETS_DIR/immich_jwt_secret"); do
    if [[ ! -s "$required_secret" ]]; then
      checkup_add critical "Missing or empty secret: $required_secret"
    fi
  done
  while IFS= read -r target; do
    backup_target_enabled "$target" || continue
    [[ -s "$(backup_target_password_file "$target")" ]] || checkup_add critical "Missing backup password file for $target."
    local repo
    repo="$(backup_target_value "$target" REPOSITORY)"
    if [[ "$repo" == sftp:* ]]; then
      local sftp_key
      sftp_key="$(backup_target_value "$target" SFTP_KEY_FILE)"
      if [[ -n "$sftp_key" && -f "$sftp_key" ]]; then
        checkup_add healthy "$target: SSH key authentication enabled (unattended)."
      else
        checkup_add warning "$target: SFTP target but SSH key not configured — will prompt for password."
        checkup_add action "Configure BACKUP_TARGET_$(uppercase_token "$target")_SFTP_KEY_FILE and run: sudo domum-media backup init $target"
      fi
    fi
    local meta_file
    meta_file="/var/lib/domum-media/backups/${target}-repo.env"
    if [[ -f "$meta_file" ]]; then
      unset REPOSITORY_ID REPOSITORY
      # shellcheck disable=SC1090
      source "$meta_file"
      checkup_add healthy "$target: repository initialized (id: ${REPOSITORY_ID:0:12})"
    else
      checkup_add warning "$target: repository not initialized. Run: sudo domum-media backup init $target"
      checkup_add action "sudo domum-media backup init $target"
    fi
    checkup_add healthy "$target: encryption = restic client-side (data encrypted before upload)."
    local include_paths broad_path
    include_paths="$(backup_target_value "$target" INCLUDE_PATHS)"
    for broad_path in "/srv/data" "/srv/media" "/srv/media/books"; do
      if [[ " $include_paths " == *" $broad_path "* ]]; then
        checkup_add warning "$target: include paths contain broad path '$broad_path' — backs up all data under that path. Run configure to switch cloud targets to immich-only."
        checkup_add action "sudo domum-media configure  # switch $target backup to immich-only"
        break
      fi
    done
  done < <(backup_target_names)

  if ! cmd_exists age; then
    checkup_add critical "age binary missing — recovery-pack create will fail. Run: apt-get install -y age"
    checkup_add action "Install age: apt-get install -y age"
  fi

  if [[ "${RECOVERY_PACK_ENABLED:-1}" == "1" ]]; then
    if recovery_pack_status >/dev/null 2>&1; then
      unset ARCHIVE_PATH TS VERIFIED_TS
      # shellcheck disable=SC1090
      source "$(recovery_pack_state_file)"
      if (( $(date +%s) - ${TS:-0} > RECOVERY_PACK_REMINDER_DAYS * 86400 )); then
        checkup_add warning "Recovery pack is older than ${RECOVERY_PACK_REMINDER_DAYS} days."
        checkup_add action "sudo domum-media recovery-pack create"
      else
        checkup_add healthy "Recovery pack age is within policy."
      fi
    else
      checkup_add critical "Recovery pack has never completed."
      checkup_add action "sudo domum-media recovery-pack create"
    fi
  fi

  local service enable_var
  while IFS='|' read -r service enable_var _ _ _ _ _; do
    [[ "${!enable_var:-0}" == "1" ]] || continue
    if wait_for_service_health "$service" 1 1; then
      checkup_add healthy "${service} healthy."
    else
      checkup_add warning "${service} is not healthy."
    fi
  done < <(service_lifecycle_specs)

  local last_success age_hours
  if last_success="$(backup_last_success_epoch)"; then
    age_hours=$(( ($(date +%s) - last_success) / 3600 ))
    if (( age_hours > BACKUP_REQUIRED_MAX_AGE_HOURS )); then
      checkup_add critical "Last successful backup is ${age_hours}h old."
    else
      checkup_add healthy "Last backup completed ${age_hours}h ago."
    fi
  else
    checkup_add critical "No successful backup timestamp found."
  fi

  local path pcent
  for path in "$DOMUM_DATA_ROOT" "$DOMUM_MEDIA_ROOT" "$DOMUM_SNAPSHOT_ROOT" /; do
    [[ -e "$path" ]] || continue
    pcent="$(df -P "$path" | awk 'NR==2 {gsub("%","",$5); print $5}')"
    if (( pcent >= 90 )); then
      checkup_add warning "$path is ${pcent}% full."
    fi
  done

  # Storage layout guardrails: durable (/srv/data) must be a distinct, protected
  # filesystem from disposable media (/srv/media), and Immich must live durable.
  if [[ -d "$DOMUM_DATA_ROOT" && -d "$DOMUM_MEDIA_ROOT" ]]; then
    local data_fsid media_fsid
    data_fsid="$(stat -c %d "$DOMUM_DATA_ROOT" 2>/dev/null || echo d)"
    media_fsid="$(stat -c %d "$DOMUM_MEDIA_ROOT" 2>/dev/null || echo m)"
    if [[ "$data_fsid" == "$media_fsid" ]]; then
      checkup_add warning "$DOMUM_MEDIA_ROOT shares a filesystem with $DOMUM_DATA_ROOT — disposable media can fill the protected disk."
      checkup_add action "Mount $DOMUM_MEDIA_ROOT on its own (OS) disk — see docs/SETUP-N100.md."
    else
      checkup_add healthy "Durable ($DOMUM_DATA_ROOT) and disposable ($DOMUM_MEDIA_ROOT) tiers are separate filesystems."
    fi
  fi
  if [[ "${ENABLE_IMMICH:-0}" == "1" ]]; then
    local immich_lib immich_pg
    immich_lib="${IMMICH_LIBRARY_DIR:-$DOMUM_DATA_ROOT/immich/library}"
    immich_pg="${IMMICH_POSTGRES_DIR:-$DOMUM_DATA_ROOT/immich/postgres}"
    if [[ "$immich_lib" != "$DOMUM_DATA_ROOT/immich/"* || "$immich_pg" != "$DOMUM_DATA_ROOT/immich/"* ]]; then
      checkup_add critical "Immich paths are not under $DOMUM_DATA_ROOT/immich (library=$immich_lib postgres=$immich_pg)."
      checkup_add action "Move Immich library + postgres under $DOMUM_DATA_ROOT/immich (durable disk)."
    else
      checkup_add healthy "Immich library + postgres are under $DOMUM_DATA_ROOT/immich."
    fi
  fi

  local dangling exited waiting_count failed_recent reset_recent
  dangling="$(docker images --filter dangling=true -q 2>/dev/null | wc -l | tr -d ' ')"
  exited="$(docker ps -a --filter status=exited -q 2>/dev/null | wc -l | tr -d ' ')"
  (( dangling > 0 )) && checkup_add warning "${dangling} dangling Docker images can be pruned."
  (( exited > 0 )) && checkup_add warning "${exited} containers are exited."
  (( dangling > 0 )) && checkup_add action "sudo domum-media cleanup images --dry-run"

  waiting_count="$(find "$DOMUM_STATE_ROOT/image-updates" -type f -name '*.env' 2>/dev/null | wc -l | tr -d ' ')"
  (( waiting_count > 0 )) && checkup_add warning "${waiting_count} service update candidates are waiting."
  [[ -f "$DOMUM_STATE_ROOT/immich/bundle-candidate.env" ]] && checkup_add warning "Immich bundle candidate is pending."

  reset_recent="$(find "$(update_history_dir)" -type f -name '*.env' -mtime -7 -print0 2>/dev/null | xargs -0 grep -l \"EVENT='delay_reset'\" 2>/dev/null | wc -l | tr -d ' ')"
  failed_recent="$(find "$(update_history_dir)" -type f -name '*.env' -mtime -30 -print0 2>/dev/null | xargs -0 grep -l \"RESULT='failure'\" 2>/dev/null | wc -l | tr -d ' ')"
  (( reset_recent > 0 )) && checkup_add warning "${reset_recent} delay-reset events in the last 7 days."
  (( failed_recent > 0 )) && checkup_add warning "${failed_recent} failed update events in the last 30 days."

  if [[ -f /var/run/reboot-required ]]; then
    checkup_add warning "Reboot required."
    checkup_add action "sudo domum-media host-upgrade --force"
  else
    checkup_add healthy "No reboot is pending."
  fi

  local sim_updates sim_security sim_general
  sim_updates="$(apt-get -s upgrade 2>/dev/null || true)"
  sim_security="$(printf '%s\n' "$sim_updates" | grep '^Inst ' | grep -ci security || true)"
  sim_general="$(printf '%s\n' "$sim_updates" | grep -c '^Inst ' || true)"
  (( sim_security > 0 )) && checkup_add warning "${sim_security} security updates are available."
  (( sim_general > 0 )) && checkup_add warning "${sim_general} general package updates are available."

  if (( json == 1 )); then
    printf '{\n'
    printf '  "critical": %s,\n' "$(json_array_from_items "${CHECKUP_CRITICAL[@]}")"
    printf '  "warnings": %s,\n' "$(json_array_from_items "${CHECKUP_WARNINGS[@]}")"
    printf '  "healthy": %s,\n' "$(json_array_from_items "${CHECKUP_HEALTHY[@]}")"
    printf '  "suggested_actions": %s\n' "$(json_array_from_items "${CHECKUP_ACTIONS[@]}")"
    printf '}\n'
  else
    echo "domum-media checkup"
    echo
    echo "Critical:"
    if (( ${#CHECKUP_CRITICAL[@]} == 0 )); then
      echo "  [✓] none"
    else
      printf '  [!] %s\n' "${CHECKUP_CRITICAL[@]}"
    fi
    echo
    echo "Warnings:"
    if (( ${#CHECKUP_WARNINGS[@]} == 0 )); then
      echo "  [✓] none"
    else
      printf '  [~] %s\n' "${CHECKUP_WARNINGS[@]}"
    fi
    echo
    echo "Healthy:"
    if (( ${#CHECKUP_HEALTHY[@]} == 0 )); then
      echo "  [~] no healthy items recorded"
    else
      printf '  [✓] %s\n' "${CHECKUP_HEALTHY[@]}"
    fi
    echo
    echo "Suggested actions:"
    if (( ${#CHECKUP_ACTIONS[@]} == 0 )); then
      echo "  1. No immediate action required."
    else
      local i=1
      local action
      for action in "${CHECKUP_ACTIONS[@]}"; do
        printf '  %d. %s\n' "$i" "$action"
        i=$(( i + 1 ))
      done
    fi
  fi

  (( ${#CHECKUP_CRITICAL[@]} == 0 ))
}

doctor_backups() {
  load_cfg
  local target
  echo "Backups:"
  if backup_last_success_epoch >/dev/null 2>&1; then
    echo "  last success: $(epoch_to_iso "$(backup_last_success_epoch)")"
  else
    echo "  last success: missing"
  fi
  echo "  enabled targets:"
  while IFS= read -r target; do
    printf '    %s\n' "$target"
  done < <(enabled_backup_targets)
}

doctor_secrets() {
  load_cfg
  echo "Secrets:"
  find "$SECRETS_DIR" -maxdepth 1 -type f 2>/dev/null | sort | while IFS= read -r file; do
    if [[ -s "$file" ]]; then
      printf '  %s: set\n' "$(basename "$file")"
    else
      printf '  %s: empty\n' "$(basename "$file")"
    fi
  done
  echo
  echo "Required binaries:"
  for bin in age restic rclone; do
    if cmd_exists "$bin"; then
      echo "  $bin: $(command -v "$bin")"
    else
      echo "  $bin: MISSING (run: apt-get install -y $bin)"
    fi
  done
  echo
  recovery_pack_status || true
}

immich_reset_db() {
  load_cfg
  export_env_for_compose

  [[ "${ENABLE_IMMICH:-0}" == "1" ]] || die "Immich is not enabled in $CFG_FILE (ENABLE_IMMICH=0)."

  local data_dir fp_file uploads_dir confirm wipe_uploads=0
  data_dir="$(immich_postgres_data_dir)"
  fp_file="$(immich_db_password_fingerprint_file)"
  uploads_dir="$(immich_library_data_dir)"

  while (( $# > 0 )); do
    case "$1" in
      --wipe-uploads) wipe_uploads=1 ;;
      *) die "Usage: domum-media immich reset-db [--wipe-uploads]" ;;
    esac
    shift
  done

  cat <<EOF
[domum-media] This will wipe the Immich Postgres database.

  Deletes: $data_dir
  Clears:  $fp_file
  Keeps:   $uploads_dir (photo blobs — unusable until re-import)
EOF
  if (( wipe_uploads == 1 )); then
    cat <<EOF
  Also deletes: $uploads_dir
EOF
  fi
  cat <<EOF

  Type exactly 'wipe immich' to confirm.
EOF

  read -r -p "> " confirm
  [[ "$confirm" == "wipe immich" ]] || die "Aborted (no changes made)."

  echo "[domum-media] Stopping Immich containers..."
  compose_cmd stop immich_server immich_machine_learning immich_postgres immich_redis 2>/dev/null || true
  compose_cmd rm -f immich_server immich_machine_learning immich_postgres immich_redis 2>/dev/null || true

  echo "[domum-media] Pre-reset btrfs snapshot..."
  snapshot_create "pre-immich-reset" || echo "[domum-media] Snapshot step failed (continuing)."

  if [[ -d "$data_dir" ]]; then
    echo "[domum-media] Removing $data_dir"
    rm -rf "$data_dir"
  fi
  if (( wipe_uploads == 1 )) && [[ -d "$uploads_dir" ]]; then
    echo "[domum-media] Removing $uploads_dir"
    rm -rf "$uploads_dir"
  fi
  if [[ -f "$fp_file" ]]; then
    echo "[domum-media] Removing $fp_file"
    rm -f "$fp_file"
  fi

  echo "[domum-media] Reapplying desired state..."
  exec /usr/local/bin/domum-media apply
}

container_exists() {
  docker inspect "$1" >/dev/null 2>&1
}

container_env_value() {
  local container_name="$1"
  local env_key="$2"

  container_exists "$container_name" || return 0
  docker inspect --format '{{range .Config.Env}}{{println .}}{{end}}' "$container_name" 2>/dev/null \
    | awk -F= -v key="$env_key" '$1 == key {print substr($0, length(key) + 2); exit}'
}

immich_runtime_env_summary() {
  local server_db server_jwt postgres_db
  local server_db_status="empty"
  local server_jwt_status="empty"
  local postgres_db_status="empty"
  local db_match="no"

  server_db="$(container_env_value immich_server DB_PASSWORD)"
  server_jwt="$(container_env_value immich_server JWT_SECRET)"
  postgres_db="$(container_env_value immich_postgres POSTGRES_PASSWORD)"

  [[ -n "$server_db" ]] && server_db_status="set"
  [[ -n "$server_jwt" ]] && server_jwt_status="set"
  [[ -n "$postgres_db" ]] && postgres_db_status="set"
  if [[ -n "$server_db" && -n "$postgres_db" && "$server_db" == "$postgres_db" ]]; then
    db_match="yes"
  fi

  echo "  immich_server DB_PASSWORD: $server_db_status"
  echo "  immich_server JWT_SECRET: $server_jwt_status"
  echo "  immich_postgres POSTGRES_PASSWORD: $postgres_db_status"
  echo "  DB_PASSWORD == POSTGRES_PASSWORD: $db_match"
}

# Non-exiting predicate: are the running Immich containers' secret env vars
# present and consistent? Used by apply() to decide whether a force-recreate
# recovery pass is warranted before hard-failing.
immich_runtime_env_ok() {
  local server_db server_jwt postgres_db
  server_db="$(container_env_value immich_server DB_PASSWORD)"
  server_jwt="$(container_env_value immich_server JWT_SECRET)"
  postgres_db="$(container_env_value immich_postgres POSTGRES_PASSWORD)"

  [[ -n "$server_db" && -n "$server_jwt" && -n "$postgres_db" && "$server_db" == "$postgres_db" ]]
}

validate_immich_runtime_env() {
  [[ "${ENABLE_IMMICH:-0}" == "1" ]] || return 0

  if ! immich_runtime_env_ok; then
    echo "[domum-media] Runtime Immich env validation:"
    immich_runtime_env_summary
    echo "[domum-media] ERROR: Rendered Compose validation passed, but running containers have empty Immich secrets. This means docker compose up did not receive the runtime secret environment." >&2
    exit 1
  fi

  echo "[domum-media] Runtime Immich env validation:"
  immich_runtime_env_summary
}

container_status_summary() {
  local container_name="$1"
  local status health

  if ! container_exists "$container_name"; then
    printf 'missing'
    return 0
  fi

  status="$(docker inspect --format '{{.State.Status}}' "$container_name" 2>/dev/null || true)"
  health="$(docker inspect --format '{{if .State.Health}}{{.State.Health.Status}}{{end}}' "$container_name" 2>/dev/null || true)"

  if [[ -n "$health" ]]; then
    printf '%s' "$health"
    return 0
  fi

  printf '%s' "${status:-unknown}"
}

container_image_ref() {
  local container_name="$1"
  container_exists "$container_name" || return 0
  docker inspect --format '{{.Config.Image}}' "$container_name" 2>/dev/null || true
}

container_mount_list() {
  local container_name="$1"
  container_exists "$container_name" || return 0
  docker inspect --format '{{range .Mounts}}{{println .Source "->" .Destination}}{{end}}' "$container_name" 2>/dev/null || true
}

doctor_immich() {
  need_root
  load_cfg
  export_env_for_compose

  [[ "${ENABLE_IMMICH:-0}" == "1" ]] || die "Immich is not enabled in $CFG_FILE (ENABLE_IMMICH=0)."

  local issues=0
  local db_file jwt_file fp_file pg_dir rendered_file
  local db_secret_status="missing"
  local jwt_secret_status="missing"
  local db_export_status="empty"
  local jwt_export_status="empty"
  local compose_db_status="empty"
  local compose_pg_status="empty"
  local compose_jwt_status="empty"
  local compose_db_match="no"
  local fingerprint_status="missing"
  local initialized="no"
  local server_db_raw server_jwt_raw postgres_db_raw
  local server_db postgres_db
  local current_digest stored_digest
  local postgres_status redis_status ml_status server_status

  db_file="$(immich_db_password_file)"
  jwt_file="$(immich_jwt_secret_file)"
  fp_file="$(immich_db_password_fingerprint_file)"
  pg_dir="$(immich_postgres_data_dir)"

  if [[ -f "$db_file" ]]; then
    if [[ -n "$(read_secret_file_value "$db_file")" ]]; then
      db_secret_status="set"
    else
      db_secret_status="empty"
      issues=1
    fi
  else
    db_secret_status="empty"
    issues=1
  fi

  if [[ -f "$jwt_file" ]]; then
    if [[ -n "$(read_secret_file_value "$jwt_file")" ]]; then
      jwt_secret_status="set"
    else
      jwt_secret_status="empty"
      issues=1
    fi
  else
    jwt_secret_status="empty"
    issues=1
  fi

  if [[ -n "${IMMICH_DB_PASSWORD:-}" ]]; then
    db_export_status="set"
  else
    issues=1
  fi
  if [[ -n "${IMMICH_JWT_SECRET:-}" ]]; then
    jwt_export_status="set"
  else
    issues=1
  fi

  if immich_db_password_initialized; then
    initialized="yes"
    if [[ -f "$fp_file" ]]; then
      if [[ -n "${IMMICH_DB_PASSWORD:-}" && -f "$db_file" ]]; then
        current_digest="$(sha256_of_file "$db_file")"
      else
        current_digest=""
      fi
      stored_digest="$(head -n1 "$fp_file" | tr -d '[:space:]')"
      if [[ -n "$current_digest" && "$current_digest" == "$stored_digest" ]]; then
        fingerprint_status="matches"
      else
        fingerprint_status="mismatch"
        issues=1
      fi
    else
      fingerprint_status="missing"
      issues=1
    fi
  else
    fingerprint_status="not-recorded"
  fi

  rendered_file="$(mktemp)"
  if render_compose_config_file "$rendered_file" 2>/dev/null; then
    server_db_raw="$(compose_rendered_env_value "$rendered_file" "immich_server" "DB_PASSWORD")"
    server_jwt_raw="$(compose_rendered_env_value "$rendered_file" "immich_server" "JWT_SECRET")"
    postgres_db_raw="$(compose_rendered_env_value "$rendered_file" "immich_postgres" "POSTGRES_PASSWORD")"

    if yaml_scalar_is_set "$server_db_raw"; then
      compose_db_status="set"
      server_db="$(yaml_scalar_plaintext "$server_db_raw")"
    fi
    if yaml_scalar_is_set "$postgres_db_raw"; then
      compose_pg_status="set"
      postgres_db="$(yaml_scalar_plaintext "$postgres_db_raw")"
    fi
    if yaml_scalar_is_set "$server_jwt_raw"; then
      compose_jwt_status="set"
    fi

    if [[ "$compose_db_status" != "set" || "$compose_pg_status" != "set" || "$compose_jwt_status" != "set" ]]; then
      issues=1
    fi

    if [[ "$compose_db_status" == "set" && "$compose_pg_status" == "set" && "$server_db" == "$postgres_db" ]]; then
      compose_db_match="yes"
    elif [[ "$compose_db_status" == "set" && "$compose_pg_status" == "set" ]]; then
      issues=1
    fi
  else
    issues=1
  fi
  rm -f "$rendered_file"

  if [[ -z "$(container_env_value immich_server DB_PASSWORD)" \
     || -z "$(container_env_value immich_server JWT_SECRET)" \
     || -z "$(container_env_value immich_postgres POSTGRES_PASSWORD)" ]]; then
    issues=1
  elif [[ "$(container_env_value immich_server DB_PASSWORD)" != "$(container_env_value immich_postgres POSTGRES_PASSWORD)" ]]; then
    issues=1
  fi

  postgres_status="$(container_status_summary immich_postgres)"
  redis_status="$(container_status_summary immich_redis)"
  ml_status="$(container_status_summary immich_machine_learning)"
  server_status="$(container_status_summary immich_server)"

  [[ "$postgres_status" == "healthy" ]] || issues=1
  [[ "$redis_status" == "healthy" ]] || issues=1
  [[ "$ml_status" == "healthy" || "$ml_status" == "running" ]] || issues=1
  [[ "$server_status" == "healthy" || "$server_status" == "running" ]] || issues=1

  echo "Immich secrets:"
  echo "  immich_db_password: $db_secret_status"
  echo "  immich_jwt_secret: $jwt_secret_status"
  echo
  echo "Exported env:"
  echo "  IMMICH_DB_PASSWORD: $db_export_status"
  echo "  IMMICH_JWT_SECRET: $jwt_export_status"
  echo
  echo "Rendered compose env:"
  echo "  DB_PASSWORD: $compose_db_status"
  echo "  POSTGRES_PASSWORD: $compose_pg_status"
  echo "  JWT_SECRET: $compose_jwt_status"
  echo "  DB_PASSWORD == POSTGRES_PASSWORD: $compose_db_match"
  echo
  echo "Running container env:"
  immich_runtime_env_summary
  echo
  echo "Database:"
  echo "  data path: $pg_dir"
  echo "  initialized: $initialized"
  echo "  password fingerprint: $fingerprint_status"
  echo
  echo "Containers:"
  echo "  immich_postgres: $postgres_status"
  echo "  immich_redis: $redis_status"
  echo "  immich_machine_learning: $ml_status"
  echo "  immich_server: $server_status"
  echo
  echo "Images:"
  echo "  immich_postgres: $(container_image_ref immich_postgres)"
  echo "  immich_redis: $(container_image_ref immich_redis)"
  echo "  immich_machine_learning: $(container_image_ref immich_machine_learning)"
  echo "  immich_server: $(container_image_ref immich_server)"
  echo
  echo "Mounts:"
  if container_exists immich_postgres; then
    while IFS= read -r mount; do
      [[ -n "$mount" ]] && echo "  immich_postgres: $mount"
    done < <(container_mount_list immich_postgres)
  else
    echo "  immich_postgres: missing"
  fi
  if container_exists immich_server; then
    while IFS= read -r mount; do
      [[ -n "$mount" ]] && echo "  immich_server: $mount"
    done < <(container_mount_list immich_server)
  else
    echo "  immich_server: missing"
  fi

  (( issues == 0 ))
}

immich_cmd() {
  need_root
  load_cfg
  export_env_for_compose
  local sub="${1:-}"
  case "$sub" in
    refresh-bundle) shift; immich_refresh_bundle "$@" ;;
    check-bundle) shift; immich_refresh_bundle --check-only "$@" ;;
    apply-bundle) shift; immich_refresh_bundle --force "$@" ;;
    rollback)
      local rollback_id
      rollback_id="$(rollback_entries | while IFS= read -r file; do
        unset ID SERVICE STATUS
        # shellcheck disable=SC1090
        source "$file"
        [[ "${SERVICE:-}" == "immich" && "${STATUS:-available}" == "available" ]] || continue
        printf '%s\n' "${ID}"
      done | tail -n 1)"
      [[ -n "$rollback_id" ]] || die "No available Immich rollback points found."
      rollback_apply_entry "$rollback_id" 0
      ;;
    reset-db) shift; immich_reset_db "$@" ;;
    *) die "Usage: domum-media immich {refresh-bundle [--force]|check-bundle|apply-bundle|rollback|reset-db [--wipe-uploads]}" ;;
  esac
}

doctor_traefik() {
  need_root
  load_cfg
  export_env_for_compose

  [[ "${ENABLE_TRAEFIK:-0}" == "1" ]] || die "Traefik is not enabled in $CFG_FILE (ENABLE_TRAEFIK=0)."

  local traefik_status traefik_image started_at ports_raw
  local entry svc host
  local -a hosts=()

  traefik_status="$(container_status_summary traefik)"
  traefik_image="$(container_image_ref traefik)"
  if container_exists traefik; then
    started_at="$(docker inspect --format '{{.State.StartedAt}}' traefik 2>/dev/null || true)"
    ports_raw="$(docker inspect --format '{{range $p, $bindings := .NetworkSettings.Ports}}{{if $bindings}}{{range $bindings}}{{println $p "->" .HostIp ":" .HostPort}}{{end}}{{else}}{{println $p "(no host binding)"}}{{end}}{{end}}' traefik 2>/dev/null || true)"
  else
    started_at=""
    ports_raw=""
  fi

  echo "Traefik container:"
  echo "  status: $traefik_status"
  echo "  image:  ${traefik_image:-unknown}"
  echo "  started: ${started_at:-n/a}"
  echo "  ports:"
  if [[ -n "$ports_raw" ]]; then
    while IFS= read -r line; do
      [[ -n "$line" ]] && echo "    $line"
    done <<<"$ports_raw"
  else
    echo "    n/a"
  fi
  echo

  hosts+=("dashboard|${TRAEFIK_DASHBOARD_HOST:-}")
  [[ "${ENABLE_JELLYFIN:-0}" == "1" ]]    && hosts+=("jellyfin|${JELLYFIN_HOST:-}")
  [[ "${ENABLE_PLEX:-0}" == "1" ]]        && hosts+=("plex|${PLEX_HOST:-}")
  [[ "${ENABLE_NAVIDROME:-0}" == "1" ]]   && hosts+=("navidrome|${NAVIDROME_HOST:-}")
  [[ "${ENABLE_CALIBRE_WEB:-0}" == "1" ]] && hosts+=("calibre-web|${CALIBRE_WEB_HOST:-}")
  [[ "${ENABLE_KAVITA:-0}" == "1" ]]      && hosts+=("kavita|${KAVITA_HOST:-}")
  [[ "${ENABLE_UPTIME_KUMA:-0}" == "1" ]] && hosts+=("uptime-kuma|status.${DOMUM_DOMAIN:-}")
  [[ "${ENABLE_IMMICH:-0}" == "1" ]]      && hosts+=("immich|photos.${DOMUM_DOMAIN:-}")

  echo "Configured hosts:"
  for entry in "${hosts[@]}"; do
    svc="${entry%%|*}"
    host="${entry#*|}"
    printf '  %-14s %s\n' "$svc" "${host:-<unset>}"
  done
  echo

  local have_dig=0
  cmd_exists dig && have_dig=1

  echo "DNS resolution:"
  for entry in "${hosts[@]}"; do
    svc="${entry%%|*}"
    host="${entry#*|}"
    [[ -n "$host" ]] || continue
    local split_view public_view
    split_view="$(getent hosts "$host" 2>/dev/null | awk '{print $1}' | paste -sd, - 2>/dev/null || true)"
    [[ -z "$split_view" ]] && split_view="<unresolved>"
    if (( have_dig )); then
      public_view="$(dig +short +time=2 +tries=1 @1.1.1.1 "$host" 2>/dev/null | paste -sd, - || true)"
      [[ -z "$public_view" ]] && public_view="<unresolved>"
    else
      public_view="<dig unavailable>"
    fi
    printf '  %-14s split=%s public=%s\n' "$svc" "$split_view" "$public_view"
  done
  echo

  echo "acme.json:"
  if container_exists traefik; then
    local acme_source acme_file
    acme_source="$(docker inspect --format '{{range .Mounts}}{{if eq .Destination "/letsencrypt"}}{{.Source}}{{end}}{{end}}' traefik 2>/dev/null || true)"
    if [[ -n "$acme_source" ]]; then
      acme_file="$acme_source/acme.json"
      if [[ -f "$acme_file" ]]; then
        local size mode owner issued_hosts state
        size="$(stat -c '%s' "$acme_file" 2>/dev/null || echo 'unknown')"
        mode="$(stat -c '%a' "$acme_file" 2>/dev/null || echo 'unknown')"
        owner="$(stat -c '%U:%G' "$acme_file" 2>/dev/null || echo 'unknown')"
        echo "  path: $acme_file"
        echo "  size: $size bytes"
        echo "  mode: $mode"
        echo "  owner: $owner"

        issued_hosts=""
        if cmd_exists jq; then
          issued_hosts="$(jq -r '
            (.cf.Certificates // [])
              | map(.domain.main, (.domain.sans // [])[])
              | unique
              | .[]
          ' "$acme_file" 2>/dev/null || true)"
        fi

        echo "  per-host certificate state:"
        for entry in "${hosts[@]}"; do
          svc="${entry%%|*}"
          host="${entry#*|}"
          [[ -n "$host" ]] || continue
          if ! cmd_exists jq; then
            state="unknown (jq not installed)"
          elif [[ -n "$issued_hosts" ]] && printf '%s\n' "$issued_hosts" | grep -Fxq -- "$host"; then
            state="issued"
          else
            state="missing"
          fi
          printf '    %-14s %-40s %s\n' "$svc" "$host" "$state"
        done
      else
        echo "  path: $acme_file (missing)"
      fi
    else
      echo "  unable to resolve traefik-letsencrypt mount source from docker inspect"
    fi
  else
    echo "  traefik container is not running"
  fi
  echo

  echo "Cloudflare token:"
  local cf_token=""
  if [[ -f "$SECRETS_DIR/cloudflare_api_token" ]]; then
    cf_token="$(read_secret_file_value "$SECRETS_DIR/cloudflare_api_token")"
  fi
  if [[ -z "$cf_token" ]]; then
    echo "  secret file: missing or empty ($SECRETS_DIR/cloudflare_api_token)"
  elif ! cmd_exists curl; then
    echo "  curl not installed — skipping token verify"
  else
    local resp
    resp="$(curl -sS --max-time 10 \
      -H "Authorization: Bearer $cf_token" \
      -H "Content-Type: application/json" \
      "https://api.cloudflare.com/client/v4/user/tokens/verify" 2>&1 || true)"
    if cmd_exists jq && jq -e . >/dev/null 2>&1 <<<"$resp"; then
      local success status_field expires not_before
      success="$(jq -r '.success' <<<"$resp")"
      status_field="$(jq -r '.result.status // "unknown"' <<<"$resp")"
      expires="$(jq -r '.result.expires_on // "n/a"' <<<"$resp")"
      not_before="$(jq -r '.result.not_before // "n/a"' <<<"$resp")"
      echo "  success: $success"
      echo "  status: $status_field"
      echo "  not_before: $not_before"
      echo "  expires_on: $expires"
      if [[ "$success" != "true" ]]; then
        echo "  errors:"
        jq -r '.errors[]? | "    [\(.code)] \(.message)"' <<<"$resp" || true
      fi
    else
      echo "  raw response: $resp"
    fi
  fi
  echo

  echo "Recent ACME log lines:"
  if container_exists traefik; then
    local logs
    logs="$(docker logs traefik 2>&1 | grep -iE 'acme|certificate|cf:' | tail -n 40 || true)"
    if [[ -n "$logs" ]]; then
      logs="  ${logs//$'\n'/$'\n  '}"
      printf '%s\n' "$logs"
    else
      echo "  (no ACME-related log lines found)"
    fi
  else
    echo "  traefik container is not running"
  fi
}

doctor_cmd() {
  need_root
  local sub="${1:-}"
  case "$sub" in
    immich) shift; doctor_immich "$@" ;;
    traefik) shift; doctor_traefik "$@" ;;
    backups) shift; doctor_backups "$@" ;;
    secrets) shift; doctor_secrets "$@" ;;
    *) die "Usage: domum-media doctor {immich|traefik|backups|secrets}" ;;
  esac
}

usage() {
  cat <<EOF
domum-media (domum-core-media)

Usage:
  domum-media init
  domum-media configure
  domum-media apply
  domum-media status [--counts]
  domum-media update
  domum-media updates {summary|check|apply|history}
  domum-media refresh-images [--force] [--check-only] [--apply-now]
  domum-media host-upgrade [--force]
  domum-media logs <service>
  domum-media backup {init <target> [--adopt-existing]|plan <target>|verify <target>|adopt-repo <target>|--check|--check-deep [repo]|--restore <snapshot> <target>}
  domum-media snapshot {create [tag]|list|prune}
  domum-media rollback {list|show <id>|apply <id> [--dry-run]}
  domum-media checkup [--json]
  domum-media cleanup {summary|images|snapshots} [--dry-run|--confirm]
  domum-media recovery-pack {create [--no-email]|status}
  domum-media doctor {immich|traefik|backups|secrets}
  domum-media immich {refresh-bundle [--force]|check-bundle|apply-bundle|rollback|reset-db [--wipe-uploads]}

Config:  $CFG_FILE
Secrets: $SECRETS_DIR
Env:     DOMUM_DIR=$DOMUM_DIR
EOF
}

main() {
  local cmd="${1:-}"
  case "$cmd" in
    init)      shift; init_host "$@" ;;
    configure) shift; configure_cmd "$@" ;;
    apply)     shift; apply "$@" ;;
    status)    shift; status "$@" ;;
    update)    shift; repo_update "$@" ;;
    updates)   shift; updates_cmd "$@" ;;
    refresh-images) shift; refresh_images "$@" ;;
    host-upgrade) shift; host_upgrade "$@" ;;
    logs)      shift; logs_cmd "$@" ;;
    backup)    backup_cmd "$@" ;;
    snapshot)  shift; snapshot_cmd "$@" ;;
    rollback)  shift; rollback_cmd "$@" ;;
    checkup)   shift; checkup_cmd "$@" ;;
    cleanup)   shift; cleanup_cmd "$@" ;;
    recovery-pack) shift; recovery_pack_cmd "$@" ;;
    doctor)    shift; doctor_cmd "$@" ;;
    immich)    shift; immich_cmd "$@" ;;
    -h|--help|help|"") usage ;;
    *) usage; exit 1 ;;
  esac
}

if [[ "${BASH_SOURCE[0]}" == "$0" ]]; then
  main "$@"
fi
