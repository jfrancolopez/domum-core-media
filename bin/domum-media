#!/usr/bin/env bash
set -euo pipefail

# domum-media — host CLI for domum-core-media.
# Adds config-driven service toggles, timer schedule syncing, and a simple
# interactive configuration flow on top of the compose + restic wrappers.

DOMUM_DIR="${DOMUM_DIR:-/opt/domum-core-media}"
CFG_FILE="${CFG_FILE:-$DOMUM_DIR/config/domum-media.conf}"
SECRETS_DIR="${SECRETS_DIR:-/etc/domum-core-media/secrets}"
DATA_ROOT_DEFAULT="/srv/data"
SNAPSHOT_ROOT_DEFAULT="/srv/snapshots"
LOG_DIR_DEFAULT="/var/log/domum-media"
STATE_ROOT_DEFAULT="/var/lib/domum-media"

die() { echo "ERROR: $*" >&2; exit 1; }

need_root() {
  [[ "${EUID}" -eq 0 ]] || die "Run as root (use sudo)."
}

cmd_exists() { command -v "$1" >/dev/null 2>&1; }

uppercase_token() {
  printf '%s' "$1" | tr '[:lower:]-' '[:upper:]_' | tr -c 'A-Z0-9_' '_'
}

load_cfg() {
  [[ -f "$CFG_FILE" ]] || die "Missing config: $CFG_FILE (copy domum-media.conf.example or run 'domum-media configure')"
  # shellcheck disable=SC1090
  source "$CFG_FILE"
  DOMUM_DATA_ROOT="${DOMUM_DATA_ROOT:-$DATA_ROOT_DEFAULT}"
  DOMUM_SNAPSHOT_ROOT="${DOMUM_SNAPSHOT_ROOT:-$SNAPSHOT_ROOT_DEFAULT}"
  DOMUM_LOG_DIR="${DOMUM_LOG_DIR:-$LOG_DIR_DEFAULT}"
  DOMUM_STATE_ROOT="${DOMUM_STATE_ROOT:-$STATE_ROOT_DEFAULT}"
}

ensure_cfg_file() {
  if [[ ! -f "$CFG_FILE" ]]; then
    echo "[domum-media] Creating config from example at $CFG_FILE"
    install -D -m 0644 "$DOMUM_DIR/config/domum-media.conf.example" "$CFG_FILE"
  fi
}

backup_target_names() {
  local names="${BACKUP_TARGETS:-nas cloud archive}"
  for name in $names; do
    [[ -n "$name" ]] && echo "$name"
  done
}

backup_target_default_enabled() {
  case "$1" in
    nas|cloud) echo "1" ;;
    *)         echo "0" ;;
  esac
}

backup_target_value() {
  local target="$1"
  local field="$2"
  local fallback="${3:-}"
  local key
  key="BACKUP_TARGET_$(uppercase_token "$target")_${field}"
  if [[ -n "${!key:-}" ]]; then
    printf '%s' "${!key}"
  else
    printf '%s' "$fallback"
  fi
}

backup_target_enabled() {
  [[ "$(backup_target_value "$1" ENABLED "$(backup_target_default_enabled "$1")")" == "1" ]]
}

backup_target_password_file() {
  backup_target_value "$1" PASSWORD_FILE "$SECRETS_DIR/restic_password_$1"
}

backup_target_legacy_env_file() {
  printf '%s/restic_%s_env' "$SECRETS_DIR" "$1"
}

backup_target_has_repository_source() {
  local target="$1"
  [[ -n "$(backup_target_value "$target" REPOSITORY)" ]] && return 0
  [[ -f "$(backup_target_legacy_env_file "$target")" ]]
}

missing_if_absent() {
  local path="$1"
  local label="$2"
  [[ -f "$path" ]] || echo "$label"
}

ensure_secret_dir() {
  install -d -m 0700 "$SECRETS_DIR"
}

ensure_state_dirs() {
  install -d -m 0700 "$DOMUM_STATE_ROOT"
  install -d -m 0700 "$DOMUM_STATE_ROOT/image-updates"
}

converge_local_installation() {
  install -m 0755 "$DOMUM_DIR/bin/domum-media" /usr/local/bin/domum-media
  install -m 0755 "$DOMUM_DIR/bin/domum-media-backup" /usr/local/bin/domum-media-backup
  install -m 0644 "$DOMUM_DIR"/systemd/*.service /etc/systemd/system/
  install -m 0644 "$DOMUM_DIR"/systemd/*.timer /etc/systemd/system/
  systemctl daemon-reload
}

write_secret_file() {
  local path="$1"
  local value="$2"
  ensure_secret_dir
  umask 077
  printf '%s' "$value" > "$path"
  chmod 600 "$path"
}

generate_secret() {
  local bytes="${1:-32}"
  openssl rand -hex "$bytes"
}

prompt_secret_value() {
  local label="$1"
  local current_file="${2:-}"
  local reply
  if [[ -n "$current_file" && -f "$current_file" ]]; then
    read -r -s -p "$label [saved, leave blank to keep]: " reply
  else
    read -r -s -p "$label: " reply
  fi
  echo
  printf '%s' "$reply"
}

prompt_multiline_value() {
  local label="$1"
  local current_file="${2:-}"
  local line content=""

  if [[ -n "$current_file" && -f "$current_file" ]]; then
    echo "$label [saved]"
  else
    echo "$label"
  fi
  echo "Enter lines now. Finish with a single '.' on its own line."
  echo "Submit just '.' to keep the current file unchanged."

  while IFS= read -r line; do
    [[ "$line" == "." ]] && break
    content+="${line}"$'\n'
  done

  printf '%s' "$content"
}

htpasswd_hash() {
  local username="$1"
  local password="$2"

  if cmd_exists htpasswd; then
    htpasswd -nbB "$username" "$password"
    return 0
  fi

  if cmd_exists docker; then
    docker run --rm --entrypoint htpasswd httpd:2.4-alpine -nbB "$username" "$password"
    return 0
  fi

  die "Need either 'htpasswd' or Docker to generate Traefik dashboard credentials."
}

managed_image_specs() {
  cat <<'EOF'
traefik|ENABLE_TRAEFIK|TRAEFIK_IMAGE|TRAEFIK_AUTO_UPDATE|TRAEFIK_AUTO_UPDATE_DELAY_DAYS|traefik
tailscale|ENABLE_TAILSCALE|TAILSCALE_IMAGE|TAILSCALE_AUTO_UPDATE|TAILSCALE_AUTO_UPDATE_DELAY_DAYS|tailscale
immich-server|ENABLE_IMMICH|IMMICH_SERVER_IMAGE|IMMICH_SERVER_AUTO_UPDATE|IMMICH_SERVER_AUTO_UPDATE_DELAY_DAYS|immich_server
immich-machine-learning|ENABLE_IMMICH|IMMICH_MACHINE_LEARNING_IMAGE|IMMICH_MACHINE_LEARNING_AUTO_UPDATE|IMMICH_MACHINE_LEARNING_AUTO_UPDATE_DELAY_DAYS|immich_machine_learning
immich-redis|ENABLE_IMMICH|IMMICH_REDIS_IMAGE|IMMICH_REDIS_AUTO_UPDATE|IMMICH_REDIS_AUTO_UPDATE_DELAY_DAYS|immich_redis
immich-postgres|ENABLE_IMMICH|IMMICH_POSTGRES_IMAGE|IMMICH_POSTGRES_AUTO_UPDATE|IMMICH_POSTGRES_AUTO_UPDATE_DELAY_DAYS|immich_postgres
jellyfin|ENABLE_JELLYFIN|JELLYFIN_IMAGE|JELLYFIN_AUTO_UPDATE|JELLYFIN_AUTO_UPDATE_DELAY_DAYS|jellyfin
navidrome|ENABLE_NAVIDROME|NAVIDROME_IMAGE|NAVIDROME_AUTO_UPDATE|NAVIDROME_AUTO_UPDATE_DELAY_DAYS|navidrome
uptime-kuma|ENABLE_UPTIME_KUMA|UPTIME_KUMA_IMAGE|UPTIME_KUMA_AUTO_UPDATE|UPTIME_KUMA_AUTO_UPDATE_DELAY_DAYS|uptime-kuma
restic-rest-server|ENABLE_RESTIC_REST_SERVER|RESTIC_REST_SERVER_IMAGE|RESTIC_REST_SERVER_AUTO_UPDATE|RESTIC_REST_SERVER_AUTO_UPDATE_DELAY_DAYS|restic-rest-server
EOF
}

# ---- compose layering ------------------------------------------------------

compose_files_for_enabled_services() {
  local files=()
  files+=("$DOMUM_DIR/compose/base.yml")

  if [[ "${ENABLE_TRAEFIK:-0}" == "1" ]]; then
    files+=("$DOMUM_DIR/compose/proxy/traefik.yml")
  fi
  if [[ "${ENABLE_TAILSCALE:-0}" == "1" ]]; then
    files+=("$DOMUM_DIR/compose/security/tailscale.yml")
  fi
  if [[ "${ENABLE_IMMICH:-0}" == "1" ]]; then
    files+=("$DOMUM_DIR/compose/photos/immich.yml")
  fi
  if [[ "${ENABLE_JELLYFIN:-0}" == "1" ]]; then
    files+=("$DOMUM_DIR/compose/media/jellyfin.yml")
  fi
  if [[ "${ENABLE_NAVIDROME:-0}" == "1" ]]; then
    files+=("$DOMUM_DIR/compose/media/navidrome.yml")
  fi
  if [[ "${ENABLE_UPTIME_KUMA:-0}" == "1" ]]; then
    files+=("$DOMUM_DIR/compose/monitoring/uptime-kuma.yml")
  fi
  if [[ "${ENABLE_RESTIC_REST_SERVER:-0}" == "1" ]]; then
    files+=("$DOMUM_DIR/compose/backups/restic-rest-server.yml")
  fi

  for f in "${files[@]}"; do
    [[ -f "$f" ]] || die "Missing compose file: $f"
    echo "-f"
    echo "$f"
  done
}

export_env_for_compose() {
  export DOMUM_DIR
  export DOMUM_DOMAIN="${DOMUM_DOMAIN:-ladomum.com}"
  export DOMUM_EMAIL="${DOMUM_EMAIL:-admin@${DOMUM_DOMAIN}}"
  export DOMUM_LAN_IP="${DOMUM_LAN_IP:-}"
  export DOMUM_TS_IP="${DOMUM_TS_IP:-}"
  export DOMUM_STATE_ROOT
  export TRAEFIK_IMAGE="${TRAEFIK_IMAGE:-traefik:v3.7.1}"
  export TRAEFIK_AUTO_UPDATE="${TRAEFIK_AUTO_UPDATE:-0}"
  export TRAEFIK_AUTO_UPDATE_DELAY_DAYS="${TRAEFIK_AUTO_UPDATE_DELAY_DAYS:-7}"
  export TRAEFIK_DASHBOARD_HOST="${TRAEFIK_DASHBOARD_HOST:-traefik-media.${DOMUM_DOMAIN}}"
  export TRAEFIK_DASHBOARD_USERS_FILE="${TRAEFIK_DASHBOARD_USERS_FILE:-$SECRETS_DIR/traefik_dashboard_users}"
  export DOMUM_DATA_ROOT
  export TAILSCALE_IMAGE="${TAILSCALE_IMAGE:-tailscale/tailscale:stable}"
  export TAILSCALE_AUTO_UPDATE="${TAILSCALE_AUTO_UPDATE:-0}"
  export TAILSCALE_AUTO_UPDATE_DELAY_DAYS="${TAILSCALE_AUTO_UPDATE_DELAY_DAYS:-7}"
  export IMMICH_SERVER_IMAGE="${IMMICH_SERVER_IMAGE:-ghcr.io/immich-app/immich-server:v1.118.2}"
  export IMMICH_SERVER_AUTO_UPDATE="${IMMICH_SERVER_AUTO_UPDATE:-0}"
  export IMMICH_SERVER_AUTO_UPDATE_DELAY_DAYS="${IMMICH_SERVER_AUTO_UPDATE_DELAY_DAYS:-7}"
  export IMMICH_MACHINE_LEARNING_IMAGE="${IMMICH_MACHINE_LEARNING_IMAGE:-ghcr.io/immich-app/immich-machine-learning:v1.118.2}"
  export IMMICH_MACHINE_LEARNING_AUTO_UPDATE="${IMMICH_MACHINE_LEARNING_AUTO_UPDATE:-0}"
  export IMMICH_MACHINE_LEARNING_AUTO_UPDATE_DELAY_DAYS="${IMMICH_MACHINE_LEARNING_AUTO_UPDATE_DELAY_DAYS:-7}"
  export IMMICH_REDIS_IMAGE="${IMMICH_REDIS_IMAGE:-docker.io/redis:6.2-alpine}"
  export IMMICH_REDIS_AUTO_UPDATE="${IMMICH_REDIS_AUTO_UPDATE:-0}"
  export IMMICH_REDIS_AUTO_UPDATE_DELAY_DAYS="${IMMICH_REDIS_AUTO_UPDATE_DELAY_DAYS:-14}"
  export IMMICH_POSTGRES_IMAGE="${IMMICH_POSTGRES_IMAGE:-tensorchord/pgvecto-rs:pg14-v0.2.0}"
  export IMMICH_POSTGRES_AUTO_UPDATE="${IMMICH_POSTGRES_AUTO_UPDATE:-0}"
  export IMMICH_POSTGRES_AUTO_UPDATE_DELAY_DAYS="${IMMICH_POSTGRES_AUTO_UPDATE_DELAY_DAYS:-14}"
  export IMMICH_DB_USERNAME="${IMMICH_DB_USERNAME:-postgres}"
  export IMMICH_DB_DATABASE_NAME="${IMMICH_DB_DATABASE_NAME:-immich}"
  export JELLYFIN_IMAGE="${JELLYFIN_IMAGE:-jellyfin/jellyfin:10.10.7}"
  export JELLYFIN_AUTO_UPDATE="${JELLYFIN_AUTO_UPDATE:-0}"
  export JELLYFIN_AUTO_UPDATE_DELAY_DAYS="${JELLYFIN_AUTO_UPDATE_DELAY_DAYS:-7}"
  export JELLYFIN_CONFIG_DIR="${JELLYFIN_CONFIG_DIR:-$DOMUM_DATA_ROOT/jellyfin/config}"
  export JELLYFIN_CACHE_DIR="${JELLYFIN_CACHE_DIR:-$DOMUM_DATA_ROOT/jellyfin/cache}"
  export JELLYFIN_MEDIA_ROOT="${JELLYFIN_MEDIA_ROOT:-/srv/media}"
  export NAVIDROME_IMAGE="${NAVIDROME_IMAGE:-deluan/navidrome:0.61.2}"
  export NAVIDROME_AUTO_UPDATE="${NAVIDROME_AUTO_UPDATE:-0}"
  export NAVIDROME_AUTO_UPDATE_DELAY_DAYS="${NAVIDROME_AUTO_UPDATE_DELAY_DAYS:-7}"
  export NAVIDROME_DATA_DIR="${NAVIDROME_DATA_DIR:-$DOMUM_DATA_ROOT/navidrome}"
  export NAVIDROME_MUSIC_ROOT="${NAVIDROME_MUSIC_ROOT:-/srv/music}"
  export NAVIDROME_USER="${NAVIDROME_USER:-0:0}"
  export NAVIDROME_SCAN_SCHEDULE="${NAVIDROME_SCAN_SCHEDULE:-@every 1h}"
  export NAVIDROME_LOG_LEVEL="${NAVIDROME_LOG_LEVEL:-info}"
  export UPTIME_KUMA_IMAGE="${UPTIME_KUMA_IMAGE:-louislam/uptime-kuma:1}"
  export UPTIME_KUMA_AUTO_UPDATE="${UPTIME_KUMA_AUTO_UPDATE:-0}"
  export UPTIME_KUMA_AUTO_UPDATE_DELAY_DAYS="${UPTIME_KUMA_AUTO_UPDATE_DELAY_DAYS:-7}"
  export RESTIC_REST_SERVER_IMAGE="${RESTIC_REST_SERVER_IMAGE:-restic/rest-server:latest}"
  export RESTIC_REST_SERVER_AUTO_UPDATE="${RESTIC_REST_SERVER_AUTO_UPDATE:-0}"
  export RESTIC_REST_SERVER_AUTO_UPDATE_DELAY_DAYS="${RESTIC_REST_SERVER_AUTO_UPDATE_DELAY_DAYS:-7}"
  export IMAGE_AUTO_UPDATE_ENABLED="${IMAGE_AUTO_UPDATE_ENABLED:-0}"
  export IMAGE_AUTO_UPDATE_AT="${IMAGE_AUTO_UPDATE_AT:-05:15}"
  export IMAGE_AUTO_UPDATE_RANDOMIZED_DELAY="${IMAGE_AUTO_UPDATE_RANDOMIZED_DELAY:-30m}"
  export HOST_PACKAGE_AUTO_UPDATE_ENABLED="${HOST_PACKAGE_AUTO_UPDATE_ENABLED:-0}"
  export HOST_PACKAGE_AUTO_UPDATE_AT="${HOST_PACKAGE_AUTO_UPDATE_AT:-Mon 05:45}"
  export HOST_PACKAGE_AUTO_UPDATE_RANDOMIZED_DELAY="${HOST_PACKAGE_AUTO_UPDATE_RANDOMIZED_DELAY:-45m}"

  if [[ -f "$SECRETS_DIR/cloudflare_api_token" ]]; then
    CF_DNS_API_TOKEN="$(cat "$SECRETS_DIR/cloudflare_api_token")"
