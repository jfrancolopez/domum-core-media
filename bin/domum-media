#!/usr/bin/env bash
set -euo pipefail

# domum-media — host CLI for domum-core-media.
# Adds config-driven service toggles, timer schedule syncing, and a simple
# interactive configuration flow on top of the compose + restic wrappers.

DOMUM_DIR="${DOMUM_DIR:-/opt/domum-core-media}"
CFG_FILE="${CFG_FILE:-$DOMUM_DIR/config/domum-media.conf}"
SECRETS_DIR="${SECRETS_DIR:-/etc/domum-core-media/secrets}"
DATA_ROOT_DEFAULT="/srv/data"
SNAPSHOT_ROOT_DEFAULT="/srv/snapshots"
LOG_DIR_DEFAULT="/var/log/domum-media"
STATE_ROOT_DEFAULT="/var/lib/domum-media"
HOT_ROOT_DEFAULT="/var/lib/domum-media/hot"

die() { echo "ERROR: $*" >&2; exit 1; }

need_root() {
  [[ "${EUID}" -eq 0 ]] || die "Run as root (use sudo)."
}

cmd_exists() { command -v "$1" >/dev/null 2>&1; }

uppercase_token() {
  printf '%s' "$1" | tr '[:lower:]-' '[:upper:]_' | tr -c 'A-Z0-9_' '_'
}

load_cfg() {
  [[ -f "$CFG_FILE" ]] || die "Missing config: $CFG_FILE (copy domum-media.conf.example or run 'domum-media configure')"
  # shellcheck disable=SC1090
  source "$CFG_FILE"
  DOMUM_DATA_ROOT="${DOMUM_DATA_ROOT:-$DATA_ROOT_DEFAULT}"
  DOMUM_SNAPSHOT_ROOT="${DOMUM_SNAPSHOT_ROOT:-$SNAPSHOT_ROOT_DEFAULT}"
  DOMUM_LOG_DIR="${DOMUM_LOG_DIR:-$LOG_DIR_DEFAULT}"
  DOMUM_STATE_ROOT="${DOMUM_STATE_ROOT:-$STATE_ROOT_DEFAULT}"
  DOMUM_HOT_ROOT="${DOMUM_HOT_ROOT:-$HOT_ROOT_DEFAULT}"
  BACKUP_POLICY="${BACKUP_POLICY:-STRICT}"
  BACKUP_REQUIRED_MAX_AGE_HOURS="${BACKUP_REQUIRED_MAX_AGE_HOURS:-48}"
}

ensure_cfg_file() {
  if [[ ! -f "$CFG_FILE" ]]; then
    echo "[domum-media] Creating config from example at $CFG_FILE"
    install -D -m 0644 "$DOMUM_DIR/config/domum-media.conf.example" "$CFG_FILE"
  fi
}

backup_target_names() {
  local names="${BACKUP_TARGETS:-nas cloud archive}"
  for name in $names; do
    [[ -n "$name" ]] && echo "$name"
  done
}

backup_target_default_enabled() {
  case "$1" in
    nas|cloud) echo "1" ;;
    *)         echo "0" ;;
  esac
}

backup_target_value() {
  local target="$1"
  local field="$2"
  local fallback="${3:-}"
  local key
  key="BACKUP_TARGET_$(uppercase_token "$target")_${field}"
  if [[ -n "${!key:-}" ]]; then
    printf '%s' "${!key}"
  else
    printf '%s' "$fallback"
  fi
}

backup_target_enabled() {
  [[ "$(backup_target_value "$1" ENABLED "$(backup_target_default_enabled "$1")")" == "1" ]]
}

backup_target_password_file() {
  backup_target_value "$1" PASSWORD_FILE "$SECRETS_DIR/restic_password_$1"
}

backup_target_legacy_env_file() {
  printf '%s/restic_%s_env' "$SECRETS_DIR" "$1"
}

backup_target_has_repository_source() {
  local target="$1"
  [[ -n "$(backup_target_value "$target" REPOSITORY)" ]] && return 0
  [[ -f "$(backup_target_legacy_env_file "$target")" ]]
}

missing_if_absent() {
  local path="$1"
  local label="$2"
  [[ -f "$path" ]] || echo "$label"
}

ensure_secret_dir() {
  install -d -m 0700 "$SECRETS_DIR"
}

ensure_state_dirs() {
  install -d -m 0700 "$DOMUM_STATE_ROOT"
  install -d -m 0700 "$DOMUM_STATE_ROOT/image-updates"
  install -d -m 0700 "$DOMUM_STATE_ROOT/immich"
  install -d -m 0700 "$DOMUM_STATE_ROOT/snapshots"
}

immich_postgres_data_dir() {
  printf '%s/immich/postgres' "$DOMUM_DATA_ROOT"
}

immich_postgres_marker() {
  printf '%s/PG_VERSION' "$(immich_postgres_data_dir)"
}

immich_db_password_file() {
  printf '%s/immich_db_password' "$SECRETS_DIR"
}

immich_jwt_secret_file() {
  printf '%s/immich_jwt_secret' "$SECRETS_DIR"
}

immich_db_password_fingerprint_file() {
  printf '%s/immich/db_password.sha256' "$DOMUM_STATE_ROOT"
}

immich_db_password_initialized() {
  [[ -f "$(immich_postgres_marker)" ]]
}

immich_library_data_dir() {
  printf '%s/immich/library' "$DOMUM_DATA_ROOT"
}

read_secret_file_value() {
  local path="$1"
  local value=""
  [[ -f "$path" ]] || return 1
  IFS= read -r -d '' value < "$path" || true
  if [[ "$value" == *$'\n' ]]; then
    value="${value%$'\n'}"
  fi
  printf '%s' "$value"
}

immich_secret_empty_error() {
  local env_name="$1"
  local secret_file="$2"
  cat >&2 <<EOF
[domum-media] ERROR: Immich is enabled but ${env_name} is empty.
Expected secret file: ${secret_file}
Run: sudo domum-media configure
EOF
  exit 1
}

load_immich_secret_exports() {
  local db_file jwt_file
  db_file="$(immich_db_password_file)"
  jwt_file="$(immich_jwt_secret_file)"

  unset IMMICH_DB_PASSWORD IMMICH_JWT_SECRET

  if [[ -f "$db_file" ]]; then
    IMMICH_DB_PASSWORD="$(read_secret_file_value "$db_file")"
    export IMMICH_DB_PASSWORD
  fi
  if [[ -f "$jwt_file" ]]; then
    IMMICH_JWT_SECRET="$(read_secret_file_value "$jwt_file")"
    export IMMICH_JWT_SECRET
  fi
}

load_runtime_secrets() {
  unset CF_DNS_API_TOKEN

  if [[ -f "$SECRETS_DIR/cloudflare_api_token" ]]; then
    CF_DNS_API_TOKEN="$(read_secret_file_value "$SECRETS_DIR/cloudflare_api_token")"
    export CF_DNS_API_TOKEN
  fi

  load_immich_secret_exports
}

validate_immich_secret_exports() {
  [[ "${ENABLE_IMMICH:-0}" == "1" ]] || return 0

  local db_file jwt_file
  db_file="$(immich_db_password_file)"
  jwt_file="$(immich_jwt_secret_file)"

  [[ -f "$db_file" ]] || immich_secret_empty_error "IMMICH_DB_PASSWORD" "$db_file"
  [[ -f "$jwt_file" ]] || immich_secret_empty_error "IMMICH_JWT_SECRET" "$jwt_file"
  [[ -n "${IMMICH_DB_PASSWORD:-}" ]] || immich_secret_empty_error "IMMICH_DB_PASSWORD" "$db_file"
  [[ -n "${IMMICH_JWT_SECRET:-}" ]] || immich_secret_empty_error "IMMICH_JWT_SECRET" "$jwt_file"
}

trim_spaces() {
  local value="$1"
  value="${value#"${value%%[![:space:]]*}"}"
  value="${value%"${value##*[![:space:]]}"}"
  printf '%s' "$value"
}

yaml_scalar_plaintext() {
  local value
  value="$(trim_spaces "$1")"
  if [[ "$value" == \"*\" && "$value" == *\" && "${#value}" -ge 2 ]]; then
    value="${value:1:${#value}-2}"
  elif [[ "$value" == \'*\' && "$value" == *\' && "${#value}" -ge 2 ]]; then
    value="${value:1:${#value}-2}"
  fi
  printf '%s' "$value"
}

yaml_scalar_is_set() {
  local value
  value="$(yaml_scalar_plaintext "$1")"
  [[ -n "$value" && "$value" != "null" && "$value" != "~" ]]
}

render_compose_config_file() {
  local output_file="$1"
  compose_cmd config > "$output_file"
}

compose_rendered_env_value() {
  local rendered_file="$1"
  local service_name="$2"
  local env_key="$3"

  awk -v service="$service_name" -v key="$env_key" '
    /^services:/ {
      in_services = 1
      next
    }
    in_services && $0 ~ "^  " service ":$" {
      in_service = 1
      in_env = 0
      next
    }
    in_service && $0 ~ "^  [^ ]" && $0 !~ "^  " service ":$" {
      in_service = 0
      in_env = 0
    }
    in_service && $0 ~ "^    environment:$" {
      in_env = 1
      next
    }
    in_service && in_env && $0 ~ "^    [^ ]" && $0 !~ "^    environment:$" {
      in_env = 0
    }
    in_service && in_env && $0 ~ "^      " key ":" {
      sub("^      " key ":[[:space:]]*", "", $0)
      print
      exit
    }
  ' "$rendered_file"
}

validate_immich_compose_config() {
  [[ "${ENABLE_IMMICH:-0}" == "1" ]] || return 0

  local rendered_file server_db_raw server_jwt_raw postgres_db_raw
  local server_db postgres_db

  validate_immich_secret_exports
  rendered_file="$(mktemp)"

  if ! render_compose_config_file "$rendered_file"; then
    rm -f "$rendered_file"
    die "docker compose config failed while validating Immich secrets."
  fi

  server_db_raw="$(compose_rendered_env_value "$rendered_file" "immich_server" "DB_PASSWORD")"
  server_jwt_raw="$(compose_rendered_env_value "$rendered_file" "immich_server" "JWT_SECRET")"
  postgres_db_raw="$(compose_rendered_env_value "$rendered_file" "immich_postgres" "POSTGRES_PASSWORD")"

  if ! yaml_scalar_is_set "$server_db_raw"; then
    rm -f "$rendered_file"
    die "Immich compose validation failed: immich_server DB_PASSWORD resolved empty from $(immich_db_password_file)"
  fi
  if ! yaml_scalar_is_set "$server_jwt_raw"; then
    rm -f "$rendered_file"
    die "Immich compose validation failed: immich_server JWT_SECRET resolved empty from $(immich_jwt_secret_file)"
  fi
  if ! yaml_scalar_is_set "$postgres_db_raw"; then
    rm -f "$rendered_file"
    die "Immich compose validation failed: immich_postgres POSTGRES_PASSWORD resolved empty from $(immich_db_password_file)"
  fi

  server_db="$(yaml_scalar_plaintext "$server_db_raw")"
  postgres_db="$(yaml_scalar_plaintext "$postgres_db_raw")"

  if [[ "$server_db" != "$postgres_db" ]]; then
    rm -f "$rendered_file"
    die "Immich compose validation failed: immich_server DB_PASSWORD and immich_postgres POSTGRES_PASSWORD do not match."
  fi

  echo "[domum-media] Immich compose env validation:"
  echo "  DB_PASSWORD: set"
  echo "  POSTGRES_PASSWORD: set"
  echo "  JWT_SECRET: set"
  echo "  DB_PASSWORD == POSTGRES_PASSWORD: yes"

  rm -f "$rendered_file"
}

sha256_of_file() {
  local path="$1"
  [[ -f "$path" ]] || return 1
  if cmd_exists sha256sum; then
    sha256sum "$path" | awk '{print $1}'
  elif cmd_exists shasum; then
    shasum -a 256 "$path" | awk '{print $1}'
  elif cmd_exists openssl; then
    openssl dgst -sha256 "$path" | awk '{print $NF}'
  else
    die "No sha256 utility available (need sha256sum, shasum, or openssl)."
  fi
}

write_immich_db_password_fingerprint() {
  local secret_file fp_file digest
  secret_file="$(immich_db_password_file)"
  fp_file="$(immich_db_password_fingerprint_file)"
  [[ -f "$secret_file" ]] || return 0
  digest="$(sha256_of_file "$secret_file")"
  install -d -m 0700 "$(dirname "$fp_file")"
  umask 077
  printf '%s\n' "$digest" > "$fp_file"
  chmod 600 "$fp_file"
}

validate_immich_db_password_state() {
  [[ "${ENABLE_IMMICH:-0}" == "1" ]] || return 0

  local secret_file fp_file pg_marker
  secret_file="$(immich_db_password_file)"
  fp_file="$(immich_db_password_fingerprint_file)"
  pg_marker="$(immich_postgres_marker)"

  validate_immich_secret_exports

  if [[ ! -f "$pg_marker" ]]; then
    # First boot path. apply() will write the fingerprint after compose up.
    return 0
  fi

  local current_digest stored_digest
  current_digest="$(sha256_of_file "$secret_file")"

  if [[ ! -f "$fp_file" ]]; then
    die "Immich Postgres data exists at $(immich_postgres_data_dir) but no password fingerprint is recorded at $fp_file.
  Refusing to apply because the original database password cannot be verified.
  Restore the original fingerprint or run: sudo domum-media immich reset-db"
  fi

  stored_digest="$(head -n1 "$fp_file" | tr -d '[:space:]')"

  if [[ "$current_digest" == "$stored_digest" ]]; then
    return 0
  fi

  cat >&2 <<EOF
[domum-media] ERROR: Immich Postgres password mismatch.

  The password stored in $secret_file
  does not match what $(immich_postgres_data_dir) was initialized with.

  Postgres only applies POSTGRES_PASSWORD during the very first initdb,
  so changing the secret after Immich was deployed leaves the database
  with the old password and Immich looping on auth failure.

  To recover, do exactly one of:

    1. Restore the previous password:
         sudo domum-media configure
       and re-enter the password Postgres was born with.

    2. Wipe the existing Immich database (DESTROYS PHOTOS METADATA;
       blobs in $DOMUM_DATA_ROOT/immich/library are untouched but unusable
       until you re-import):
         sudo domum-media immich reset-db

  Refusing to apply.
EOF
  exit 1
}

converge_local_installation() {
  install -m 0755 "$DOMUM_DIR/bin/domum-media" /usr/local/bin/domum-media
  install -m 0755 "$DOMUM_DIR/bin/domum-media-backup" /usr/local/bin/domum-media-backup
  install -m 0644 "$DOMUM_DIR"/systemd/*.service /etc/systemd/system/
  install -m 0644 "$DOMUM_DIR"/systemd/*.timer /etc/systemd/system/
  systemctl daemon-reload
}

write_secret_file() {
  local path="$1"
  local value="$2"
  ensure_secret_dir
  umask 077
  printf '%s' "$value" > "$path"
  chmod 600 "$path"
}

generate_secret() {
  local bytes="${1:-32}"
  openssl rand -hex "$bytes"
}

prompt_secret_value() {
  local label="$1"
  local current_file="${2:-}"
  local reply
  if [[ -n "$current_file" && -f "$current_file" ]]; then
    read -r -s -p "$label [saved, leave blank to keep]: " reply
  else
    read -r -s -p "$label: " reply
  fi
  echo
  printf '%s' "$reply"
}

prompt_multiline_value() {
  local label="$1"
  local current_file="${2:-}"
  local line content=""

  if [[ -n "$current_file" && -f "$current_file" ]]; then
    echo "$label [saved]"
  else
    echo "$label"
  fi
  echo "Enter lines now. Finish with a single '.' on its own line."
  echo "Submit just '.' to keep the current file unchanged."

  while IFS= read -r line; do
    [[ "$line" == "." ]] && break
    content+="${line}"$'\n'
  done

  printf '%s' "$content"
}

htpasswd_hash() {
  local username="$1"
  local password="$2"

  if cmd_exists htpasswd; then
    htpasswd -nbB "$username" "$password"
    return 0
  fi

  if cmd_exists docker; then
    docker run --rm --entrypoint htpasswd httpd:2.4-alpine -nbB "$username" "$password"
    return 0
  fi

  die "Need either 'htpasswd' or Docker to generate Traefik dashboard credentials."
}

managed_image_specs() {
  cat <<'EOF'
traefik|ENABLE_TRAEFIK|TRAEFIK_IMAGE|TRAEFIK_AUTO_UPDATE|TRAEFIK_AUTO_UPDATE_DELAY_DAYS|traefik
tailscale|ENABLE_TAILSCALE|TAILSCALE_IMAGE|TAILSCALE_AUTO_UPDATE|TAILSCALE_AUTO_UPDATE_DELAY_DAYS|tailscale
jellyfin|ENABLE_JELLYFIN|JELLYFIN_IMAGE|JELLYFIN_AUTO_UPDATE|JELLYFIN_AUTO_UPDATE_DELAY_DAYS|jellyfin
plex|ENABLE_PLEX|PLEX_IMAGE|PLEX_AUTO_UPDATE|PLEX_AUTO_UPDATE_DELAY_DAYS|plex
navidrome|ENABLE_NAVIDROME|NAVIDROME_IMAGE|NAVIDROME_AUTO_UPDATE|NAVIDROME_AUTO_UPDATE_DELAY_DAYS|navidrome
calibre-web|ENABLE_CALIBRE_WEB|CALIBRE_WEB_IMAGE|CALIBRE_WEB_AUTO_UPDATE|CALIBRE_WEB_AUTO_UPDATE_DELAY_DAYS|calibre-web
kavita|ENABLE_KAVITA|KAVITA_IMAGE|KAVITA_AUTO_UPDATE|KAVITA_AUTO_UPDATE_DELAY_DAYS|kavita
uptime-kuma|ENABLE_UPTIME_KUMA|UPTIME_KUMA_IMAGE|UPTIME_KUMA_AUTO_UPDATE|UPTIME_KUMA_AUTO_UPDATE_DELAY_DAYS|uptime-kuma
restic-rest-server|ENABLE_RESTIC_REST_SERVER|RESTIC_REST_SERVER_IMAGE|RESTIC_REST_SERVER_AUTO_UPDATE|RESTIC_REST_SERVER_AUTO_UPDATE_DELAY_DAYS|restic-rest-server
EOF
}

service_lifecycle_specs() {
  cat <<'EOF'
traefik|ENABLE_TRAEFIK|A|14|traefik|TRAEFIK_IMAGE|
tailscale|ENABLE_TAILSCALE|A|14|tailscale|TAILSCALE_IMAGE|
uptime-kuma|ENABLE_UPTIME_KUMA|A|14|uptime-kuma|UPTIME_KUMA_IMAGE|
jellyfin|ENABLE_JELLYFIN|B|21|jellyfin|JELLYFIN_IMAGE|
plex|ENABLE_PLEX|B|20|plex|PLEX_IMAGE|
navidrome|ENABLE_NAVIDROME|B|21|navidrome|NAVIDROME_IMAGE|
calibre-web|ENABLE_CALIBRE_WEB|B|20|calibre-web|CALIBRE_WEB_IMAGE|
kavita|ENABLE_KAVITA|B|20|kavita|KAVITA_IMAGE|
immich|ENABLE_IMMICH|C|21|immich_server immich_machine_learning immich_postgres immich_redis|IMMICH_SERVER_IMAGE|
EOF
}

service_data_path() {
  case "$1" in
    traefik) echo "$DOMUM_DATA_ROOT/traefik" ;;
    immich) echo "$DOMUM_DATA_ROOT/immich" ;;
    jellyfin) echo "${JELLYFIN_CONFIG_DIR%/config}" ;;
    plex) echo "${PLEX_CONFIG_DIR%/config}" ;;
    navidrome) echo "$NAVIDROME_DATA_DIR" ;;
    calibre-web) echo "${CALIBRE_WEB_CONFIG_DIR%/config}" ;;
    kavita) echo "${KAVITA_CONFIG_DIR%/config}" ;;
    uptime-kuma) echo "$DOMUM_DATA_ROOT/uptime-kuma" ;;
    *) return 1 ;;
  esac
}

service_configured_version() {
  local key="$1"
  printf '%s' "${!key:-unknown}"
}

service_backup_required() {
  case "$1" in
    jellyfin|plex|navidrome|calibre-web|kavita|immich) return 0 ;;
    *) return 1 ;;
  esac
}

service_compose_services() {
  while IFS='|' read -r name _ _ _ compose_svcs _ _; do
    [[ "$name" == "$1" ]] || continue
    printf '%s' "$compose_svcs"
    return 0
  done < <(service_lifecycle_specs)
  return 1
}

service_health_url() {
  while IFS='|' read -r name _ _ _ _ _ url; do
    [[ "$name" == "$1" ]] || continue
    printf '%s' "$url"
    return 0
  done < <(service_lifecycle_specs)
  return 1
}

backup_last_success_epoch() {
  local file="${DOMUM_LOG_DIR}/last-success"
  [[ -f "$file" ]] || return 1
  date -d "$(head -n1 "$file")" +%s 2>/dev/null || return 1
}

verify_backup_freshness() {
  local svc="$1"
  service_backup_required "$svc" || return 0

  local policy="${BACKUP_POLICY^^}"
  local max_age_hours="${BACKUP_REQUIRED_MAX_AGE_HOURS:-48}"
  local now last_success age_hours
  now="$(date +%s)"
  if ! last_success="$(backup_last_success_epoch)"; then
    if [[ "$policy" == "STRICT" ]]; then
      die "Refusing to update $svc: no successful backup timestamp found in $DOMUM_LOG_DIR/last-success"
    fi
    echo "[domum-media] WARNING: no successful backup timestamp found; continuing because BACKUP_POLICY=$BACKUP_POLICY"
    return 0
  fi
  age_hours=$(( (now - last_success) / 3600 ))
  if (( age_hours > max_age_hours )); then
    if [[ "$policy" == "STRICT" ]]; then
      die "Refusing to update $svc: latest successful backup is ${age_hours}h old (limit ${max_age_hours}h)"
    fi
    echo "[domum-media] WARNING: latest successful backup for $svc is ${age_hours}h old; continuing because BACKUP_POLICY=$BACKUP_POLICY"
  fi
}

service_is_healthy() {
  local svc="$1"
  local compose_svcs cid health_url

  compose_svcs="$(service_compose_services "$svc" || true)"
  for compose_svc in $compose_svcs; do
    cid="$(tracked_service_container_id "$compose_svc")"
    [[ -n "$cid" ]] || return 1
    if [[ "$(docker inspect --format '{{.State.Status}}' "$cid" 2>/dev/null || true)" != "running" ]]; then
      return 1
    fi
    if [[ "$(docker inspect --format '{{if .State.Health}}{{.State.Health.Status}}{{end}}' "$cid" 2>/dev/null || true)" == "unhealthy" ]]; then
      return 1
    fi
  done

  health_url="$(service_health_url "$svc" || true)"
  if [[ -n "$health_url" ]] && cmd_exists curl; then
    curl -fsS --max-time 10 "$health_url" >/dev/null 2>&1 || return 1
  fi

  return 0
}

# ---- compose layering ------------------------------------------------------

compose_files_for_enabled_services() {
  local files=()
  files+=("$DOMUM_DIR/compose/base.yml")

  if [[ "${ENABLE_TRAEFIK:-0}" == "1" ]]; then
    files+=("$DOMUM_DIR/compose/proxy/traefik.yml")
  fi
  if [[ "${ENABLE_TAILSCALE:-0}" == "1" ]]; then
    files+=("$DOMUM_DIR/compose/security/tailscale.yml")
  fi
  if [[ "${ENABLE_IMMICH:-0}" == "1" ]]; then
    files+=("$DOMUM_DIR/compose/photos/immich.yml")
  fi
  if [[ "${ENABLE_JELLYFIN:-0}" == "1" ]]; then
    files+=("$DOMUM_DIR/compose/media/jellyfin.yml")
  fi
  if [[ "${ENABLE_PLEX:-0}" == "1" ]]; then
    files+=("$DOMUM_DIR/compose/media/plex.yml")
  fi
  if [[ "${ENABLE_NAVIDROME:-0}" == "1" ]]; then
    files+=("$DOMUM_DIR/compose/media/navidrome.yml")
  fi
  if [[ "${ENABLE_CALIBRE_WEB:-0}" == "1" ]]; then
    files+=("$DOMUM_DIR/compose/media/calibre-web.yml")
  fi
  if [[ "${ENABLE_KAVITA:-0}" == "1" ]]; then
    files+=("$DOMUM_DIR/compose/media/kavita.yml")
  fi
  if [[ "${ENABLE_UPTIME_KUMA:-0}" == "1" ]]; then
    files+=("$DOMUM_DIR/compose/monitoring/uptime-kuma.yml")
  fi
  if [[ "${ENABLE_RESTIC_REST_SERVER:-0}" == "1" ]]; then
    files+=("$DOMUM_DIR/compose/backups/restic-rest-server.yml")
  fi

  for f in "${files[@]}"; do
    [[ -f "$f" ]] || die "Missing compose file: $f"
    echo "-f"
    echo "$f"
  done
}

export_env_for_compose() {
  export DOMUM_DIR
  export DOMUM_DOMAIN="${DOMUM_DOMAIN:-ladomum.com}"
  export DOMUM_EMAIL="${DOMUM_EMAIL:-admin@${DOMUM_DOMAIN}}"
  export DOMUM_LAN_IP="${DOMUM_LAN_IP:-}"
  export DOMUM_TS_IP="${DOMUM_TS_IP:-}"
  export DOMUM_STATE_ROOT
  export DOMUM_HOT_ROOT="${DOMUM_HOT_ROOT:-$HOT_ROOT_DEFAULT}"
  export TRAEFIK_IMAGE="${TRAEFIK_IMAGE:-traefik:v3.7.1}"
  export TRAEFIK_AUTO_UPDATE="${TRAEFIK_AUTO_UPDATE:-0}"
  export TRAEFIK_AUTO_UPDATE_DELAY_DAYS="${TRAEFIK_AUTO_UPDATE_DELAY_DAYS:-7}"
  export TRAEFIK_DASHBOARD_HOST="${TRAEFIK_DASHBOARD_HOST:-traefik-media.${DOMUM_DOMAIN}}"
  export TRAEFIK_DASHBOARD_USERS_FILE="${TRAEFIK_DASHBOARD_USERS_FILE:-$SECRETS_DIR/traefik_dashboard_users}"
  export DOMUM_DATA_ROOT
  export TAILSCALE_IMAGE="${TAILSCALE_IMAGE:-tailscale/tailscale:stable}"
  export TAILSCALE_AUTO_UPDATE="${TAILSCALE_AUTO_UPDATE:-0}"
  export TAILSCALE_AUTO_UPDATE_DELAY_DAYS="${TAILSCALE_AUTO_UPDATE_DELAY_DAYS:-7}"
