#!/usr/bin/env bash
set -euo pipefail

# domum-media-backup — restic wrapper invoked by systemd timers and the CLI.
#
# Backups are now driven by BACKUP_TARGET_* entries in config/domum-media.conf.
# Each enabled target can be a plain restic repository string, an NFS-mounted
# repo, or an FTP target reached via restic's rclone backend.

DOMUM_DIR="${DOMUM_DIR:-/opt/domum-core-media}"
CFG_FILE="${CFG_FILE:-$DOMUM_DIR/config/domum-media.conf}"
SECRETS_DIR="${SECRETS_DIR:-/etc/domum-core-media/secrets}"
REPO_META_DIR="${REPO_META_DIR:-/var/lib/domum-media/backups}"

die() { echo "ERROR: $*" >&2; exit 1; }
log() { echo "[$(date -Iseconds)] $*" | tee -a "$LOG_FILE" >&2; }

need_root() { [[ "${EUID}" -eq 0 ]] || die "Run as root (use sudo)."; }
cmd_exists() { command -v "$1" >/dev/null 2>&1; }

uppercase_token() {
  printf '%s' "$1" | tr '[:lower:]-' '[:upper:]_' | tr -c 'A-Z0-9_' '_'
}

load_cfg() {
  [[ -f "$CFG_FILE" ]] || die "Missing config: $CFG_FILE"
  # shellcheck disable=SC1090
  source "$CFG_FILE"
  DOMUM_DATA_ROOT="${DOMUM_DATA_ROOT:-/srv/data}"
  DOMUM_MEDIA_ROOT="${DOMUM_MEDIA_ROOT:-/srv/media}"
  DOMUM_SNAPSHOT_ROOT="${DOMUM_SNAPSHOT_ROOT:-/srv/snapshots}"
  DOMUM_LOG_DIR="${DOMUM_LOG_DIR:-/var/log/domum-media}"
  RESTIC_KEEP_DAILY="${RESTIC_KEEP_DAILY:-7}"
  RESTIC_KEEP_WEEKLY="${RESTIC_KEEP_WEEKLY:-5}"
  RESTIC_KEEP_MONTHLY="${RESTIC_KEEP_MONTHLY:-12}"
  RESTIC_KEEP_YEARLY="${RESTIC_KEEP_YEARLY:-3}"
  BACKUP_DEEP_CHECK_PERCENT="${BACKUP_DEEP_CHECK_PERCENT:-10%}"
  # Global fallback for targets without an explicit *_INCLUDE_PATHS. Durable
  # state only — never the disposable /srv/media media disk by default.
  BACKUP_INCLUDE_PATHS="${BACKUP_INCLUDE_PATHS:-/srv/data}"
}

# Immich-only profile: photos + database dump + recovery pack. This is the
# default for the cloud target so large media libraries are never uploaded.
immich_only_include_paths() {
  printf '%s/immich/library %s/immich/backup-staging /var/lib/domum-media/recovery-pack' \
    "$DOMUM_DATA_ROOT" "$DOMUM_DATA_ROOT"
}

export_compose_env() {
  export DOMUM_DOMAIN="${DOMUM_DOMAIN:-ladomum.com}"
  export DOMUM_DATA_ROOT
  export IMMICH_DB_USERNAME="${IMMICH_DB_USERNAME:-postgres}"
  export IMMICH_DB_DATABASE_NAME="${IMMICH_DB_DATABASE_NAME:-immich}"

  if [[ -f "$SECRETS_DIR/immich_db_password" ]]; then
    IMMICH_DB_PASSWORD="$(cat "$SECRETS_DIR/immich_db_password")"
    export IMMICH_DB_PASSWORD
  fi
  if [[ -f "$SECRETS_DIR/immich_jwt_secret" ]]; then
    IMMICH_JWT_SECRET="$(cat "$SECRETS_DIR/immich_jwt_secret")"
    export IMMICH_JWT_SECRET
  fi
}

ensure_dirs() {
  mkdir -p "$DOMUM_LOG_DIR"
  LOG_FILE="$DOMUM_LOG_DIR/backup.log"
  HEARTBEAT_FILE="$DOMUM_LOG_DIR/last-success"
  touch "$LOG_FILE"
}

require_files() {
  local missing=()
  for f in "$@"; do
    [[ -f "$f" ]] || missing+=("$f")
  done
  if (( ${#missing[@]} > 0 )); then
    die "Missing required files: ${missing[*]}"
  fi
}

backup_target_names() {
  local names="${BACKUP_TARGETS:-nas cloud}"
  for name in $names; do
    [[ -n "$name" ]] && echo "$name"
  done
}

backup_target_default_enabled() {
  case "$1" in
    nas|cloud) echo "1" ;;
    *)         echo "0" ;;
  esac
}

backup_target_value() {
  local target="$1"
  local field="$2"
  local fallback="${3:-}"
  local key
  key="BACKUP_TARGET_$(uppercase_token "$target")_${field}"
  if [[ -n "${!key:-}" ]]; then
    printf '%s' "${!key}"
  else
    printf '%s' "$fallback"
  fi
}

backup_target_enabled() {
  [[ "$(backup_target_value "$1" ENABLED "$(backup_target_default_enabled "$1")")" == "1" ]]
}

backup_target_password_file() {
  backup_target_value "$1" PASSWORD_FILE "$SECRETS_DIR/restic_password_$1"
}

shell_join_quoted() {
  local joined=""
  printf -v joined '%q ' "$@"
  printf '%s' "${joined% }"
}

sftp_command_option_for_target() {
  local target="$1"
  local sftp_key sftp_known_hosts sftp_port
  local -a ssh_cmd=()
  sftp_key="$(backup_target_value "$target" SFTP_KEY_FILE)"
  sftp_known_hosts="$(backup_target_value "$target" SFTP_KNOWN_HOSTS_FILE)"
  sftp_port="$(backup_target_value "$target" SFTP_PORT)"
  [[ -n "$sftp_key" ]] || die "SFTP target '$target' is missing BACKUP_TARGET_$(uppercase_token "$target")_SFTP_KEY_FILE."
  require_files "$sftp_key"
  ssh_cmd=(ssh -F /dev/null -i "$sftp_key")
  ssh_cmd+=(-o IdentitiesOnly=yes)
  ssh_cmd+=(-o PreferredAuthentications=publickey)
  ssh_cmd+=(-o PasswordAuthentication=no)
  ssh_cmd+=(-o StrictHostKeyChecking=yes)
  if [[ -n "$sftp_known_hosts" ]]; then
    require_files "$sftp_known_hosts"
    ssh_cmd+=(-o UserKnownHostsFile="$sftp_known_hosts")
  fi
  if [[ -n "$sftp_port" ]]; then
    ssh_cmd+=(-p "$sftp_port")
  fi
  printf 'sftp.command=%s' "$(shell_join_quoted "${ssh_cmd[@]}")"
}

backup_env_line_is_valid() {
  local line="$1"
  [[ "$line" =~ ^[[:space:]]*$ ]] && return 0
  [[ "$line" =~ ^[[:space:]]*# ]] && return 0
  [[ "$line" =~ ^[[:space:]]*(export[[:space:]]+)?[A-Za-z_][A-Za-z0-9_]*= ]] && return 0
  return 1
}

validate_backup_env_file() {
  local path="$1"
  local line
  bash -n "$path" >/dev/null 2>&1 || return 1
  while IFS= read -r line || [[ -n "$line" ]]; do
    backup_env_line_is_valid "$line" || return 1
  done < "$path"
}

source_backup_env_file() {
  local path="$1"
  validate_backup_env_file "$path" \
    || die "Invalid backup env file: $path. It must contain valid shell export/key=value lines."
  set +u
  # shellcheck disable=SC1090
  source "$path" \
    || die "Invalid backup env file: $path. It must contain valid shell export/key=value lines."
  set -u
}

backup_target_retention() {
  case "$1" in
    nas)   backup_target_value "$1" RETENTION "daily" ;;
    cloud) backup_target_value "$1" RETENTION "weekly" ;;
    *)     backup_target_value "$1" RETENTION "none" ;;
  esac
}

backup_target_include_paths() {
  local target="$1"
  local paths target_default
  paths="$(backup_target_value "$target" INCLUDE_PATHS)"
  # The cloud target defaults to immich-only so /srv/media is never swept off-site.
  case "$target" in
    cloud) target_default="$(immich_only_include_paths)" ;;
    *)     target_default="${BACKUP_INCLUDE_PATHS:-/srv/data}" ;;
  esac
  printf '%s' "${paths:-$target_default}"
}

repo_meta_file() {
  printf '%s' "$REPO_META_DIR/$1-repo.env"
}

get_repo_id() {
  local target="$1"
  restic_for_target "$target" cat config 2>/dev/null \
    | grep -oE '"id"[[:space:]]*:[[:space:]]*"[0-9a-f]+"' \
    | grep -oE '[0-9a-f]{8,}' | head -1
}

check_repo_identity() {
  local target="$1"
  local meta_file
  meta_file="$(repo_meta_file "$target")"
  [[ -f "$meta_file" ]] || return 0
  local saved_id current_id
  unset REPOSITORY_ID
  # shellcheck disable=SC1090
  source "$meta_file"
  saved_id="${REPOSITORY_ID:-}"
  [[ -n "$saved_id" ]] || return 0
  current_id="$(get_repo_id "$target")"
  [[ -n "$current_id" ]] || return 0
  if [[ "$current_id" != "$saved_id"* && "$saved_id" != "$current_id"* ]]; then
    die "ERROR: $target restic repository ID mismatch.
  Expected: $saved_id
  Current:  $current_id
  This usually means BACKUP_TARGET_$(uppercase_token "$target")_REPOSITORY or port changed.
  Run: sudo domum-media backup adopt-repo $target"
  fi
}

backup_target_legacy_env_file() {
  printf '%s/restic_%s_env' "$SECRETS_DIR" "$1"
}

backup_target_exists() {
  local target="$1"
  while IFS= read -r name; do
    [[ "$name" == "$target" ]] && return 0
  done < <(backup_target_names)
  return 1
}

default_restore_target() {
  if backup_target_exists nas && backup_target_enabled nas; then
    echo "nas"
    return 0
  fi
  while IFS= read -r name; do
    backup_target_enabled "$name" || continue
    echo "$name"
    return 0
  done < <(backup_target_names)
  die "No enabled backup targets found."
}

default_full_check_target() {
  if backup_target_exists cloud && backup_target_enabled cloud; then
    echo "cloud"
    return 0
  fi
  default_restore_target
}

# Quiesce Immich Postgres: take a btrfs snapshot of the postgres data dir,
# then run pg_dump from inside the postgres container into the staging
# location alongside the photo library.
quiesce_immich_postgres() {
  local pg_subvol="$DOMUM_DATA_ROOT/immich/postgres"
  local stage_dir="$DOMUM_DATA_ROOT/immich/backup-staging"
  mkdir -p "$stage_dir"

  if [[ ! -d "$pg_subvol" ]]; then
    log "Skipping Immich quiesce: $pg_subvol absent."
    return 0
  fi

  if command -v btrfs >/dev/null 2>&1 && btrfs subvolume show "$pg_subvol" >/dev/null 2>&1; then
    local snap
    snap="$DOMUM_SNAPSHOT_ROOT/immich-postgres-prebackup-$(date +%Y%m%d-%H%M%S)"
    mkdir -p "$DOMUM_SNAPSHOT_ROOT"
    log "btrfs snapshot: $pg_subvol -> $snap"
    btrfs subvolume snapshot -r "$pg_subvol" "$snap" >/dev/null
  fi

  local dump_file="$stage_dir/immich-postgres.dump.sql.gz"
  local pg_user="${IMMICH_DB_USERNAME:-postgres}"
  local pg_db="${IMMICH_DB_DATABASE_NAME:-immich}"
  local pg_cid
  pg_cid="$(docker ps --filter "name=immich_postgres" --filter "status=running" -q 2>/dev/null | head -1)"
  if [[ -n "$pg_cid" ]]; then
    log "pg_dump immich -> $dump_file"
    docker exec -i "$pg_cid" pg_dump -U "$pg_user" -d "$pg_db" | gzip -9 > "$dump_file"
    log "pg_dump complete"
  else
    log "Immich postgres container not running — skipping pg_dump."
    return 1
  fi
}

restic_with_env() {
  local pw_file="$1"
  local repository="$2"
  local env_file="${3:-}"
  local rclone_config="${4:-}"
  local restic_option="${5:-}"
  shift 5
  require_files "$pw_file"

  (
    if [[ -n "$env_file" && -f "$env_file" ]]; then
      source_backup_env_file "$env_file"
    fi
    export RESTIC_PASSWORD_FILE="$pw_file"
    export RESTIC_REPOSITORY="$repository"
    if [[ -n "$rclone_config" ]]; then
      export RCLONE_CONFIG="$rclone_config"
    fi
    local -a restic_cmd=(restic)
    if [[ -n "$restic_option" ]]; then
      restic_cmd+=(-o "$restic_option")
    fi
    restic_cmd+=("$@")
    "${restic_cmd[@]}"
  )
}

restic_for_target() {
  local target="$1"
  shift

  local target_type pw_file
  target_type="$(backup_target_value "$target" TYPE repository)"
  pw_file="$(backup_target_password_file "$target")"

  case "$target_type" in
    repository)
      local repository env_file extra_env_file sftp_command_opt
      repository="$(backup_target_value "$target" REPOSITORY)"
      env_file="$(backup_target_legacy_env_file "$target")"
      extra_env_file="$(backup_target_value "$target" ENV_FILE)"
      if [[ -n "$repository" ]]; then
        if [[ "$repository" == sftp:* ]]; then
          sftp_command_opt="$(sftp_command_option_for_target "$target")"
        fi
        restic_with_env "$pw_file" "$repository" "$extra_env_file" "" "$sftp_command_opt" "$@"
        return 0
      fi
      require_files "$env_file" "$pw_file"
      (
        source_backup_env_file "$env_file"
        export RESTIC_PASSWORD_FILE="$pw_file"
        local -a restic_cmd=(restic)
        if [[ "${RESTIC_REPOSITORY:-}" == sftp:* ]]; then
          sftp_command_opt="$(sftp_command_option_for_target "$target")"
          restic_cmd+=(-o "$sftp_command_opt")
        fi
        restic_cmd+=("$@")
        "${restic_cmd[@]}"
      )
      ;;
    nfs)
      local remote mount_point repository mounted_here=0 rc
      remote="$(backup_target_value "$target" NFS_REMOTE)"
      mount_point="$(backup_target_value "$target" NFS_MOUNT_POINT)"
      repository="$(backup_target_value "$target" REPOSITORY)"
      [[ -n "$remote" && -n "$mount_point" && -n "$repository" ]] || die "Incomplete NFS config for target '$target'"
      mkdir -p "$mount_point"
      if ! mountpoint -q "$mount_point"; then
        mount -t nfs "$remote" "$mount_point"
        mounted_here=1
      fi
      set +e
      restic_with_env "$pw_file" "$repository" "" "" "" "$@"
      rc=$?
      set -e
      if (( mounted_here )); then
        umount "$mount_point"
      fi
      return "$rc"
      ;;
    ftp)
      local host port remote_name path user_file pass_file tmp_cfg obscured_pass rc
      host="$(backup_target_value "$target" FTP_HOST)"
      port="$(backup_target_value "$target" FTP_PORT 21)"
      remote_name="$(backup_target_value "$target" FTP_REMOTE_NAME "$target")"
      path="$(backup_target_value "$target" FTP_PATH "/domum-media")"
      user_file="$(backup_target_value "$target" FTP_USERNAME_FILE "$SECRETS_DIR/${target}_ftp_username")"
      pass_file="$(backup_target_value "$target" FTP_PASSWORD_FILE "$SECRETS_DIR/${target}_ftp_password")"
      [[ -n "$host" ]] || die "Missing FTP host for target '$target'"
      require_files "$pw_file" "$user_file" "$pass_file"
      cmd_exists rclone || die "rclone is required for FTP backup targets."
      obscured_pass="$(rclone obscure "$(cat "$pass_file")")"
      tmp_cfg="$(mktemp)"
      cat > "$tmp_cfg" <<EOF
[${remote_name}]
type = ftp
host = ${host}
port = ${port}
user = $(cat "$user_file")
pass = ${obscured_pass}
EOF
      set +e
      restic_with_env "$pw_file" "rclone:${remote_name}:${path}" "" "$tmp_cfg" "" "$@"
      rc=$?
      set -e
      rm -f "$tmp_cfg"
      return "$rc"
      ;;
    *)
      die "Unknown backup target type '$target_type' for '$target'"
      ;;
  esac
}

enabled_backup_targets() {
  while IFS= read -r target; do
    backup_target_enabled "$target" || continue
    echo "$target"
  done < <(backup_target_names)
}

retention_targets() {
  local cadence="$1"
  while IFS= read -r target; do
    [[ "$(backup_target_retention "$target")" == "$cadence" ]] || continue
    echo "$target"
  done < <(enabled_backup_targets)
}

restic_backup_to() {
  local target="$1"
  local paths=()
  local path
  for path in $(backup_target_include_paths "$target"); do
    [[ -e "$path" ]] || continue
    paths+=("$path")
  done
  log "restic backup -> $target"
  restic_for_target "$target" backup \
    --tag "$(date +%Y-%m-%d)" \
    --exclude "$DOMUM_DATA_ROOT/immich/backup-staging/*.tmp" \
    --exclude "${DOMUM_MEDIA_ROOT}/.cache/*" \
    "${paths[@]}"
}

restic_forget_for() {
  local target="$1"
  log "restic forget --prune on $target"
  restic_for_target "$target" forget --prune \
    --keep-daily   "$RESTIC_KEEP_DAILY" \
    --keep-weekly  "$RESTIC_KEEP_WEEKLY" \
    --keep-monthly "$RESTIC_KEEP_MONTHLY" \
    --keep-yearly  "$RESTIC_KEEP_YEARLY"
}

restic_check_for() {
  local target="$1"
  shift
  log "restic check on $target $*"
  restic_for_target "$target" check "$@"
}

list_latest_snapshots() {
  local any=0
  while IFS= read -r target; do
    any=1
    echo "-- $target --"
    if ! restic_for_target "$target" snapshots --latest 1 2>&1; then
      echo "(failed to query snapshots for $target)"
    fi
  done < <(enabled_backup_targets)
  (( any == 1 )) || echo "(no enabled backup targets)"
}

heartbeat() {
  date -Iseconds > "$HEARTBEAT_FILE"
  if [[ -n "${BACKUP_HEARTBEAT_URL:-}" ]]; then
    curl -fsS --max-time 10 -o /dev/null "$BACKUP_HEARTBEAT_URL" || true
  fi
}

do_daily_backup() {
  local ran_any=0
  log "=== daily backup start ==="
  local pg_dump_ok=1
  quiesce_immich_postgres || pg_dump_ok=0
  if (( pg_dump_ok == 0 )) && [[ "${ENABLE_IMMICH:-0}" == "1" ]]; then
    case "${BACKUP_POLICY:-BALANCED}" in
      STRICT)   die "Immich is enabled but pg_dump failed/skipped. Aborting in STRICT mode." ;;
      BALANCED) log "WARNING: Immich pg_dump failed/skipped. Continuing in BALANCED mode." ;;
      LENIENT)  log "INFO: Immich pg_dump failed/skipped. Continuing in LENIENT mode." ;;
    esac
  fi

  while IFS= read -r target; do
    ran_any=1
    check_repo_identity "$target"
    restic_backup_to "$target"
  done < <(enabled_backup_targets)

  while IFS= read -r target; do
    restic_forget_for "$target"
  done < <(retention_targets daily)

  (( ran_any == 1 )) || die "No enabled backup targets configured."

  heartbeat
  if [[ "${RECOVERY_PACK_ENABLED:-1}" == "1" ]] && command -v /usr/local/bin/domum-media >/dev/null 2>&1; then
    log "refresh recovery-pack"
    /usr/local/bin/domum-media recovery-pack create --no-email || log "recovery-pack refresh failed"
  fi
  log "=== daily backup ok ==="
}

do_weekly_retention() {
  local ran_any=0
  while IFS= read -r target; do
    ran_any=1
    restic_forget_for "$target"
  done < <(retention_targets weekly)
  (( ran_any == 1 )) || log "No weekly-retention targets configured."
}

do_check() {
  while IFS= read -r target; do
    check_repo_identity "$target"
    restic_check_for "$target"
  done < <(enabled_backup_targets)
}

do_check_deep() {
  local target="${1:-$(default_restore_target)}"
  check_repo_identity "$target"
  restic_check_for "$target" --read-data-subset="$BACKUP_DEEP_CHECK_PERCENT"
}

do_check_full() {
  local target="${1:-$(default_full_check_target)}"
  check_repo_identity "$target"
  restic_check_for "$target" --read-data
}

do_restore() {
  local snap="${1:-}"
  local target_dir="${2:-}"
  local repo
  repo="$(default_restore_target)"
  shift 2 || true
  while (( $# )); do
    case "$1" in
      --repo)
        repo="$2"
        shift 2
        ;;
      *)
        die "Unknown restore arg: $1"
        ;;
    esac
  done
  [[ -n "$snap" && -n "$target_dir" ]] || die "Usage: --restore <snapshot> <target> [--repo target-name]"
  log "restic restore $snap -> $target_dir (from $repo)"
  mkdir -p "$target_dir"
  restic_for_target "$repo" restore "$snap" --target "$target_dir"
}

do_init_repo() {
  local target="${1:-}"
  local adopt=0
  [[ -n "$target" ]] || die "Usage: backup init <target> [--adopt-existing]"
  shift || true
  while (( $# )); do
    case "$1" in
      --adopt-existing) adopt=1 ;;
      *) die "Usage: backup init <target> [--adopt-existing]" ;;
    esac
    shift
  done

  load_cfg
  export_compose_env

  local repository
  repository="$(backup_target_value "$target" REPOSITORY)"
  [[ -n "$repository" ]] || die "No BACKUP_TARGET_$(uppercase_token "$target")_REPOSITORY configured."

  mkdir -p "$REPO_META_DIR"
  local meta_file
  meta_file="$(repo_meta_file "$target")"
  if [[ -f "$meta_file" ]] && (( adopt == 0 )); then
    die "Repository metadata already exists at $meta_file. Use --adopt-existing to overwrite."
  fi

  log "Initializing $target repository: $repository"
  if restic_for_target "$target" snapshots >/dev/null 2>&1; then
    if (( adopt == 0 )); then
      log "Repository already initialized. Using existing repo."
    else
      log "Repository exists. Adopting."
    fi
  else
    log "Repository not found. Running restic init..."
    restic_for_target "$target" init || die "Failed to init repository."
  fi

  local repo_id
  repo_id="$(get_repo_id "$target")"
  [[ -n "$repo_id" ]] || die "Failed to get repository ID. Check connectivity and password."

  log "Repository ID: $repo_id"
  mkdir -p "$REPO_META_DIR"
  cat > "$meta_file" <<EOF
TARGET="$target"
REPOSITORY="$repository"
REPOSITORY_ID="$repo_id"
INIT_TS="$(date -Iseconds)"
EOF
  log "Saved metadata to $meta_file"

  log "Verifying connectivity..."
  restic_for_target "$target" snapshots --latest 1 || die "Failed to read snapshots after init."
  log "Repository initialized and ready."
}

do_plan_target() {
  local target="${1:-}"
  [[ -n "$target" ]] || die "Usage: backup plan <target>"

  load_cfg
  local repository
  repository="$(backup_target_value "$target" REPOSITORY)"
  [[ -n "$repository" ]] || die "No BACKUP_TARGET_$(uppercase_token "$target")_REPOSITORY configured."

  local meta_file repo_id
  meta_file="$(repo_meta_file "$target")"
  if [[ -f "$meta_file" ]]; then
    unset REPOSITORY_ID
    # shellcheck disable=SC1090
    source "$meta_file"
    repo_id="${REPOSITORY_ID:0:16}"
  else
    repo_id="(run: sudo domum-media backup init $target)"
  fi

  echo "Backup plan for target: $target"
  echo "  Repository: $repository"
  echo "  Repo ID: $repo_id"
  echo "  Encryption: restic client-side encryption — data encrypted locally before upload"
  echo
  echo "Include paths:"
  local path
  for path in $(backup_target_include_paths "$target"); do
    if [[ -e "$path" ]]; then
      echo "  ✓ $path"
    else
      echo "  ⚠ $path (missing on disk)"
    fi
  done
  echo
  echo "Excluded paths (by design):"
  echo "  /srv/media/movies (media: not included)"
  echo "  /srv/media/tv (media: not included)"
  echo "  /srv/media/music (media: not included)"
  echo "  /srv/media/books (media: not included)"
  echo "  /srv/data/jellyfin (media app: not included)"
  echo "  /srv/data/plex (media app: not included)"
  echo "  /srv/data/navidrome (music app: not included)"
  echo "  /srv/data/calibre-web (ebook app: not included)"
  echo "  /srv/data/kavita (comics app: not included)"
}

do_verify_target() {
  local target="${1:-}"
  [[ -n "$target" ]] || die "Usage: backup verify <target>"

  load_cfg
  export_compose_env

  log "Verifying repository: $target"
  log "--- snapshots (latest 1) ---"
  restic_for_target "$target" snapshots --latest 1

  log "--- metadata check ---"
  restic_for_target "$target" check

  log "--- storage stats (best-effort) ---"
  restic_for_target "$target" stats --mode restore-size || true

  log "Verification complete."
}

do_adopt_repo() {
  local target="${1:-}"
  [[ -n "$target" ]] || die "Usage: backup adopt-repo <target>"

  load_cfg
  export_compose_env

  local repository
  repository="$(backup_target_value "$target" REPOSITORY)"
  [[ -n "$repository" ]] || die "No BACKUP_TARGET_$(uppercase_token "$target")_REPOSITORY configured."

  log "Adopting current repository for $target: $repository"
  local repo_id
  repo_id="$(get_repo_id "$target")" || die "Failed to connect to repository. Check configuration."

  log "Current repository ID: $repo_id"

  mkdir -p "$REPO_META_DIR"
  local meta_file
  meta_file="$(repo_meta_file "$target")"
  cat > "$meta_file" <<EOF
TARGET="$target"
REPOSITORY="$repository"
REPOSITORY_ID="$repo_id"
INIT_TS="$(date -Iseconds)"
ADOPTED=1
EOF
  log "Repository adopted. Metadata saved to $meta_file"
}

main() {
  need_root
  load_cfg
  export_compose_env
  ensure_dirs

  case "${1:-}" in
    "")                   do_daily_backup ;;
    --check)              do_check ;;
    --check-deep)         shift; do_check_deep "${1:-}" ;;
    --check-cloud-deep)   shift; do_check_full "${1:-}" ;;
    --weekly-retention)   do_weekly_retention ;;
    --weekly-cloud-forget) do_weekly_retention ;;
    --restore)            shift; do_restore "$@" ;;
    --snapshots)          list_latest_snapshots ;;
    init)                 shift; do_init_repo "$@" ;;
    plan)                 shift; do_plan_target "${1:-}" ;;
    verify)               shift; do_verify_target "${1:-}" ;;
    adopt-repo)           shift; do_adopt_repo "${1:-}" ;;
    -h|--help)
      cat <<EOF
domum-media-backup — restic wrapper

Usage:
  domum-media-backup                         Daily backup for all enabled targets
  domum-media-backup --check                Metadata check on all enabled targets
  domum-media-backup --check-deep [target]  Read-data-subset check on one target
  domum-media-backup --check-cloud-deep [target]
                                            Full read-data check on one target
  domum-media-backup --weekly-retention     Run weekly retention targets
  domum-media-backup --restore <snap> <target> [--repo target-name]
  domum-media-backup --snapshots            Show latest snapshot per target
  domum-media-backup init <target> [--adopt-existing]
                                            Initialize restic repository
  domum-media-backup plan <target>          Show what would be backed up
  domum-media-backup verify <target>        Verify repository health
  domum-media-backup adopt-repo <target>    Adopt existing repository by ID
EOF
      ;;
    *)
      die "Unknown command: $1 (try --help)"
      ;;
  esac
}

main "$@"
